@dp.message(InputStates.waiting_phone)
async def phone_analysis(message: types.Message, state: FSMContext):
    phone = message.text.strip()
    
    # Проверка белого списка
    if is_whitelisted(phone=phone):
        await message.answer("❌ **Доступ запрещен!**\n\nЭтот номер защищен белым списком.", parse_mode="Markdown")
        await state.clear()
        await message.answer("Что делаем дальше?", reply_markup=main_menu())
        return
    
    await message.answer("📊 Анализирую номер...")
    
    try:
        parsed = phonenumbers.parse(phone, None)
        if not phonenumbers.is_valid_number(parsed):
            await message.answer("❌ Неверный формат номера")
            await state.clear()
            await message.answer("Что дальше?", reply_markup=main_menu())
            return
        
        country = geocoder.description_for_number(parsed, "ru")
        operator = carrier.name_for_number(parsed, "ru")
        formatted_int = phonenumbers.format_number(parsed, phonenumbers.PhoneNumberFormat.INTERNATIONAL)
        
        result = f"""
📞 **Результат анализа номера**

**Номер:** `{formatted_int}`
**Страна:** {country}
**Оператор:** {operator if operator else 'Не определен'}
**Валидность:** ✅ Да
"""
        await message.answer(result, parse_mode="Markdown")
    except:
        await message.answer("❌ Ошибка при анализе номера")
    
    await state.clear()
    await message.answer("Что дальше?", reply_markup=main_menu())


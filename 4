@dp.message(InputStates.waiting_promocode)
async def process_promocode(message: types.Message, state: FSMContext):
    code = message.text.strip().upper()
    user_id = message.from_user.id
    username = message.from_user.username
    phone = None
    
    if code not in promocodes:
        await message.answer("❌ Неверный промокод. Попробуй еще раз.")
        return
    
    if promocodes[code]["used"]:
        await message.answer("❌ Этот промокод уже был использован.")
        return
    
    # Добавляем в белый список
    add_to_whitelist(user_id, username, phone, code)
    promocodes[code]["used"] = True
    promocodes[code]["used_by"] = user_id
    promocodes[code]["user_data"] = {"username": username, "phone": phone}
    save_promocodes(promocodes)
    
    await message.answer(
        "✅ **Ты добавлен в белый список!**\n\n"
        "Теперь твои данные защищены:\n"
        f"• Telegram ID: `{user_id}`\n"
        f"• Username: @{username if username else 'не указан'}\n\n"
        "Никто не сможет найти тебя через этого бота.",
        parse_mode="Markdown"
    )
    await state.clear()
    await message.answer("Что делаем дальше?", reply_markup=main_menu())


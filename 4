@dp.message(InputStates.waiting_dork_query)
async def process_dork(message: types.Message, state: FSMContext):
    query = message.text.strip()
    user_data = await state.get_data()
    dork_type = user_data.get("dork_type", "person")
    
    templates = {
        "person": [f'"username" site:instagram.com', f'"username" site:t.me', f'"username" site:facebook.com'],
        "email": [f'site:example.com "@gmail.com"', f'filetype:pdf "@gmail.com"'],
        "docs": [f'filetype:pdf "{query}"', f'filetype:xls "{query}"', f'filetype:log "{query}"'],
        "admin": [f'site:{query} inurl:admin', f'site:{query} inurl:login', f'site:{query} intitle:"admin panel"'],
        "secret": [f'site:{query} filetype:env', f'site:{query} filetype:json "api_key"']
    }
    
    dorks = [t.replace("username", query).replace("example.com", query) for t in templates.get(dork_type, [])]
    
    result = f"🔎 **Google Dork для `{query}`**\n\n" + "\n\n".join(dorks)
    await message.answer(result[:4000], parse_mode="Markdown")
    await state.clear()

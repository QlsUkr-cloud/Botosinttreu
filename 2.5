@dp.message(SearchStates.waiting_phone_extended)
async def extended_search(message: types.Message, state: FSMContext):
    user_id = message.from_user.id
    phone = message.text.strip()
    phone_clean = re.sub(r'\D', '', phone)
    
    if len(phone_clean) < 7:
        await message.answer("❌ Введіть коректний номер (мінімум 7 цифр)")
        return
    
    await message.answer(get_text(user_id, "searching", query=phone) + "\n" + get_text(user_id, "loading"))
    
    # Спершу звичайний пошук
    simple_results = await asyncio.to_thread(db_searcher.search_phone, phone)
    
    if simple_results:
        await message.answer(f"✅ Початковий пошук: знайдено {len(simple_results)} записів для номера {phone}")
        
        # Показуємо перші результати
        for row in simple_results[:3]:
            formatted = format_extended_result(row)
            if formatted:
                await message.answer(formatted)
        
        await message.answer("🔄 **ЗАПУСКАЮ РЕКУРСИВНИЙ ПОШУК...**")
        await message.answer("⏳ Це може зайняти деякий час, бот шукає всі зв'язки...")
        
        # Запускаємо рекурсивний пошук
        recursive_result = await recursive_search(user_id, phone, "phone", max_iterations=3)
        
        if recursive_result['total_records'] > 0:
            # Формуємо фінальний звіт
            final_report = format_final_report(user_id, recursive_result)
            
            # Розбиваємо довге повідомлення на частини
            max_len = 4000
            for i in range(0, len(final_report), max_len):
                await message.answer(final_report[i:i+max_len])
        else:
            await message.answer("❌ Під час рекурсивного пошуку нічого нового не знайдено")
    
    else:
        await message.answer(f"❌ Нічого не знайдено для номера {phone}\n\n📊 Перевірено {len(db_searcher.all_data)} записів")
    
    await state.clear()
    await message.answer(get_text(user_id, "main_menu"), reply_markup=main_menu(user_id))


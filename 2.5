    lines.append(f"📈 **Статистика:**")
    lines.append(f"   • Всього знайдено записів: {search_result['total_records']}")
    lines.append(f"   • Унікальних ФІО: {len(search_result['unique_names'])}")
    lines.append(f"   • Унікальних номерів: {len(search_result['unique_phones'])}")
    lines.append("")
    
    # Знайдені ФІО
    if search_result['unique_names']:
        lines.append("👤 **Знайдені ФІО:**")
        for name in search_result['unique_names'][:10]:
            lines.append(f"   • {name}")
        if len(search_result['unique_names']) > 10:
            lines.append(f"   ... та ще {len(search_result['unique_names']) - 10}")
        lines.append("")
    
    # Знайдені номери
    if search_result['unique_phones']:
        lines.append("📞 **Знайдені номери:**")
        for phone in search_result['unique_phones'][:10]:
            lines.append(f"   • {phone}")
        if len(search_result['unique_phones']) > 10:
            lines.append(f"   ... та ще {len(search_result['unique_phones']) - 10}")
        lines.append("")
    
    # Всі записи
    lines.append("📋 **ВСІ ЗНАЙДЕНІ ЗАПИСИ:**")
    lines.append("─" * 40)
    
    for i, row in enumerate(search_result['results'][:20], 1):
        formatted = format_extended_result(row)
        if formatted:
            lines.append(f"\n🔸 **Запис #{i}**")
            lines.append(formatted)
            lines.append("─" * 40)
    
    if search_result['total_records'] > 20:
        lines.append(f"\n⚠️ Показано перші 20 з {search_result['total_records']} записів")
    
    return "\n".join(lines)


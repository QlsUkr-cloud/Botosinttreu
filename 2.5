@dp.message(SearchStates.waiting_iin)
async def iin_analyze(message: types.Message, state: FSMContext):
    user_id = message.from_user.id
    iin = message.text.strip().replace(" ", "").replace("-", "")
    
    if re.match(r'^\d{12}$', iin):
        year = 1900 + int(iin[0:2]) if int(iin[6]) in [3,4] else 2000 + int(iin[0:2])
        gender = "Чоловіча" if int(iin[6]) % 2 == 1 else "Жіноча"
        result = f"🇰🇿 ІІН Казахстан\n📅 Дата: {iin[4:6]}.{iin[2:4]}.{year}\n👤 Стать: {gender}"
    elif re.match(r'^\d{11}$', iin):
        result = f"🇷🇺 СНІЛС Росія\n📋 Номер: {iin[:3]}-{iin[3:6]}-{iin[6:9]} {iin[9:11]}"
    elif re.match(r'^\d{10}$', iin):
        result = f"🇺🇦 ІНН Україна\n📋 Код: {iin}"
    elif re.match(r'^\d{9}$', iin):
        result = f"🇧🇾 УНП Білорусь\n📋 Номер: {iin[:2]}-{iin[2:5]}-{iin[5:9]}"
    else:
        result = "❌ Невірний формат"
    
    await message.answer(result)
    await state.clear()
    await message.answer(get_text(user_id, "main_menu"), reply_markup=main_menu(user_id))


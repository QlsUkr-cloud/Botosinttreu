@dp.message(SearchStates.waiting_phone_analyze)
async def phone_analyze(message: types.Message, state: FSMContext):
    user_id = message.from_user.id
    phone = message.text.strip()
    
    try:
        parsed = phonenumbers.parse(phone, None)
        if not phonenumbers.is_valid_number(parsed):
            await message.answer("❌ Невірний формат номера")
            await state.clear()
            await message.answer(get_text(user_id, "main_menu"), reply_markup=main_menu(user_id))
            return
        
        country = geocoder.description_for_number(parsed, "ru")
        operator = carrier.name_for_number(parsed, "ru")
        
        result = f"📊 Аналіз номера\n\n📞 Номер: {phone}\n🌍 Країна: {country}\n📡 Оператор: {operator if operator else 'Не визначено'}\n✅ Статус: Валідний"
        await message.answer(result)
    except Exception as e:
        await message.answer(f"❌ Помилка: {str(e)[:100]}")
    

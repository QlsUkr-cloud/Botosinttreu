@dp.message(SearchStates.waiting_promo)
async def process_promo(message: types.Message, state: FSMContext):
    user_id = message.from_user.id
    code = message.text.strip().upper()
    data = await state.get_data()
    next_action = data.get("next_action", "menu")
    
    if code not in promocodes:
        await message.answer(get_text(user_id, "promo_invalid"))
        await state.clear()
        await message.answer(get_text(user_id, "main_menu"), reply_markup=main_menu(user_id))
        return
    
    if promocodes[code]["used"]:
        await message.answer(get_text(user_id, "promo_used"))
        await state.clear()
        await message.answer(get_text(user_id, "main_menu"), reply_markup=main_menu(user_id))
        return
    
    promocodes[code]["used"] = True
    promocodes[code]["used_by"] = user_id
    save_promocodes(promocodes)
    user_promocodes[user_id] = code
    
    await message.answer(get_text(user_id, "promo_activated"))
    
    if next_action == "gmail":
        await message.answer(get_text(user_id, "enter_gmail"))
        await state.set_state(SearchStates.waiting_gmail)
    else:
        await state.clear()
        await message.answer(get_text(user_id, "main_menu"), reply_markup=main_menu(user_id))


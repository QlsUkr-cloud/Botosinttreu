    record = result["data"]
    fio = record.get("fio", "")
    
    # Шукаємо додаткову інформацію за ФІО
    if fio:
        fio_results = await asyncio.to_thread(db_searcher.search_fio, fio, country)
        if fio_results:
            for extra in fio_results:
                extra_record = extra["data"]
                for key, value in extra_record.items():
                    if value and not record.get(key):
                        record[key] = value
    
    formatted = format_recursive_result({"country": country, "data": record})
    
    # ШІ-аналіз
    if ai_enabled:
        await message.answer(get_text(user_id, "ai_analyze"))

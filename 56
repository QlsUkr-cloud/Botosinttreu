                                {"role": "system", "content": "Ти експерт з OSINT аналізу. Аналізуй знайдені дані коротко українською."},
                                {"role": "user", "content": f"Проаналізуй ці дані та напиши короткий висновок:\n{formatted}"}
                            ],
                            timeout=30
                        )
                        await message.answer(f"🤖 ШІ-аналіз:\n{ai_response.choices[0].message.content}")
                    except Exception as e:
                        logging.error(f"AI помилка: {e}")
    
    await state.clear()
    await message.answer(get_text(user_id, "main_menu"), reply_markup=get_main_menu(user_id))


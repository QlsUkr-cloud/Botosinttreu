                ],
                timeout=30
            )
            ai_analysis = f"\n\n━" * 40 + f"\n\n🤖 ШТУЧНИЙ ІНТЕЛЕКТ (АНАЛІЗ)\n\n{ai_response.choices[0].message.content}"
            formatted += ai_analysis
        except Exception as e:
            logging.error(f"AI помилка: {e}")
    
    await message.answer(formatted, reply_markup=get_main_menu(user_id))
    await state.clear()


def write_csv(filepath, data):
    """Запис даних в CSV файл"""
    try:
        with open(filepath, 'w', encoding='utf-8', newline='') as f:
            writer = csv.writer(f)
            writer.writerow(["phone", "fio", "also", "region", "date", "operator", "email", "telegram", "tiktok", "ip", "car", "iin", "passport", "address", "card"])
            for row in data:
                writer.writerow(row)
        print(f"✅ Створено/оновлено: {filepath}")
    except Exception as e:
        print(f"❌ Помилка створення {filepath}: {e}")

class DatabaseSearcher:
    def __init__(self):
        self.databases = {}
        self.loaded = False
    
    def load_all_databases(self):
        """Завантаження всіх баз даних"""
        print("\n" + "=" * 60)
        print("📂 ЗАВАНТАЖЕННЯ БАЗ ДАНИХ")
        print("=" * 60)
        
        for country, filepath in DATABASE_FILES.items():
            try:
                if os.path.exists(filepath):
                    data = []
                    with open(filepath, 'r', encoding='utf-8') as f:
                        reader = csv.reader(f)
                        headers = next(reader)  # пропускаємо заголовки
                        for row in reader:
                            if row and len(row) >= 15:
                                record = {
                                    "phone": row[0],
                                    "fio": row[1],
                                    "also": row[2],
                                    "region": row[3],
                                    "date": row[4],
                                    "operator": row[5],
                                    "email": row[6],
                                    "telegram": row[7],
                                    "tiktok": row[8],
                                    "ip": row[9],
                                    "car": row[10],
                                    "iin": row[11],
                                    "passport": row[12],
                                    "address": row[13],
                                    "card": row[14],
                                }
                                data.append(record)
                    self.databases[country] = data
                    print(f"✅ {country}: {len(data)} записів")
                else:
                    self.databases[country] = []
                    print(f"⚠️ {country}: файл не знайдено")
            except Exception as e:
                self.databases[country] = []
                print(f"❌ {country}: помилка - {e}")
        
        print("=" * 60)
        self.loaded = True
        return self.databases
    
    def search_phone(self, phone, country=None):
        """Пошук за номером телефону в базі"""
        if not self.loaded:
            self.load_all_databases()
        
        phone_clean = re.sub(r'\D', '', phone)
        results = []
        
        # Якщо вибрана конкретна країна
        if country:
            for record in self.databases.get(country, []):
                record_phone = re.sub(r'\D', '', record.get('phone', ''))
                if record_phone == phone_clean or phone_clean in record_phone:
                    results.append({"country": country, "data": record})
        else:
            # Шукаємо у всіх базах
            for country_name, records in self.databases.items():
                for record in records:
                    record_phone = re.sub(r'\D', '', record.get('phone', ''))
                    if record_phone == phone_clean or phone_clean in record_phone:
                        results.append({"country": country_name, "data": record})
        
        return results
    
    def search_fio(self, fio, country=None):
        """Пошук за ФІО в базі"""
        if not self.loaded:
            self.load_all_databases()
        
        fio_lower = fio.lower()
        results = []
        
        if country:
            for record in self.databases.get(country, []):
                record_fio = record.get('fio', '').lower()
                if fio_lower in record_fio:
                    results.append({"country": country, "data": record})
        else:
            for country_name, records in self.databases.items():
                for record in records:
                    record_fio = record.get('fio', '').lower()
                    if fio_lower in record_fio:
                        results.append({"country": country_name, "data": record})
        
        return results
    
    def search_iin(self, iin, country=None):
        """Пошук за ІІН в базі"""
        if not self.loaded:
            self.load_all_databases()
        
        iin_clean = re.sub(r'\D', '', iin)
        results = []
        
        if country:
            for record in self.databases.get(country, []):
                record_iin = re.sub(r'\D', '', record.get('iin', ''))
                if record_iin and (record_iin == iin_clean or iin_clean in record_iin):
                    results.append({"country": country, "data": record})
        else:
            for country_name, records in self.databases.items():
                for record in records:
                    record_iin = re.sub(r'\D', '', record.get('iin', ''))
                    if record_iin and (record_iin == iin_clean or iin_clean in record_iin):
                        results.append({"country": country_name, "data": record})
        
        return results


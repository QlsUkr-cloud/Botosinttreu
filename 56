def format_search_result(result):
    """Форматування результату пошуку"""
    if not result:
        return None
    
    record = result["data"]
    country = result["country"]
    
    output = f"🔍 РЕЗУЛЬТАТ ПОШУКУ\n"
    output += f"🗄️ База: {country}\n"
    output += "━" * 40 + "\n\n"
    
    output += f"📞 Телефон: {record.get('phone', '❌ Не знайдено')}\n"
    output += f"👤 ФІО: {record.get('fio', '❌ Не знайдено')}\n"
    
    if record.get('also'):
        output += f"👥 Також: {record.get('also')}\n"
    if record.get('region'):
        output += f"📍 Регіон: {record.get('region')}\n"
    if record.get('date'):
        output += f"📅 Дата: {record.get('date')}\n"
    if record.get('operator'):
        output += f"🏦 Оператор: {record.get('operator')}\n"
    if record.get('email'):
        output += f"📧 Email: {record.get('email')}\n"
    if record.get('telegram'):
        output += f"📱 Telegram: {record.get('telegram')}\n"
    if record.get('tiktok'):
        output += f"🎵 TikTok: {record.get('tiktok')}\n"
    if record.get('ip'):
        output += f"🌐 IP: {record.get('ip')}\n"
    if record.get('car'):
        output += f"🚗 Авто: {record.get('car')}\n"
    if record.get('iin'):
        output += f"🆔 ІІН: {record.get('iin')}\n"
    if record.get('passport'):
        output += f"🪪 Паспорт: {record.get('passport')}\n"
    if record.get('address'):
        output += f"🏠 Адреса: {record.get('address')}\n"
    if record.get('card'):
        output += f"💳 Карта: {record.get('card')}\n"
    
    return output


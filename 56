@dp.message(SearchStates.waiting_url)
async def webarchive_check(message: types.Message, state: FSMContext):
    user_id = message.from_user.id
    url = message.text.strip()
    await message.answer("📁 Шукаю архівні копії...")
    
    try:
        encoded_url = urllib.parse.quote(url, safe='')
        archive_url = f"https://archive.org/wayback/available?url={encoded_url}"
        
        async with aiohttp.ClientSession() as session:
            async with session.get(archive_url, timeout=15) as response:
                if response.status == 200:
                    data = await response.json()
                    if data.get("archived_snapshots"):
                        snapshot = data["archived_snapshots"]["closest"]
                        await message.answer(f"📁 Архівна копія: {snapshot.get('url', 'немає')}")
                    else:
                        await message.answer("❌ Архівних копій не знайдено")
                else:
                    await message.answer("❌ Помилка при зверненні до архіву")
    except Exception as e:
        await message.answer(f"❌ Помилка: {str(e)[:100]}")
    
    await state.clear()
    await message.answer(get_text(user_id, "main_menu"), reply_markup=get_main_menu(user_id))


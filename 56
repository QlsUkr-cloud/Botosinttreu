        with open(PROMOCODES_FILE, "r", encoding="utf-8") as f:
            return json.load(f)
    promocodes = {}
    for i in range(50):
        code = secrets.token_hex(4).upper()
        promocodes[code] = {"used": False, "used_by": None}
    save_promocodes(promocodes)
    return promocodes


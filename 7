@dp.message(InputStates.waiting_dork_query)
async def process_dork(message: types.Message, state: FSMContext):
    query = message.text.strip()
    user_data = await state.get_data()
    dork_type = user_data.get("dork_type", "person")
    
    await message.answer(f"🔎 Выполняю поиск для `{query}`...\nЭто может занять до 30 секунд.", parse_mode="Markdown")
    
    # Генерация дьорков
    templates = {
        "person": [f'"{query}" site:instagram.com', f'"{query}" site:t.me', f'"{query}" site:facebook.com', f'"{query}" site:twitter.com', f'"{query}" site:vk.com'],
        "email": [f'"{query}" filetype:pdf', f'"{query}" site:pastebin.com'],
        "docs": [f'filetype:pdf "{query}"', f'filetype:xls "{query}"', f'filetype:doc "{query}"'],
        "admin": [f'site:{query} inurl:admin', f'site:{query} inurl:login', f'site:{query} intitle:"admin"'],
        "secret": [f'site:{query} filetype:env', f'site:{query} filetype:json "api"', f'site:{query} filetype:conf']
    }
    
    dorks = [t.replace("{query}", query).replace("example.com", query) for t in templates.get(dork_type, [])]
    
    # Симуляция поиска (в реальности нужен API)
    results = []
    for dork in dorks:
        results.append(f"📌 `{dork}`")
    
    last_dork_results[message.from_user.id] = {
        "query": query,
        "type": dork_type,
        "dorks": dorks,
        "results": results
    }
    
    result_text = f"🔎 **Google Dork для `{query}`**\n\n"
    result_text += "\n".join(results)
    result_text += f"\n\n📊 **Сгенерировано дьорков:** {len(dorks)}\n\n💡 *Скопируй эти запросы в Google для поиска.*\n\nНажми 'Сохранить в файл', чтобы экспортировать результаты."
    
    await message.answer(result_text[:4000], parse_mode="Markdown")
    await state.clear()
    
    # Кнопка сохранения
    save_btn = InlineKeyboardMarkup(inline_keyboard=[[InlineKeyboardButton(text="📥 Сохранить в файл", callback_data="dork_save")]])
    await message.answer("Что дальше?", reply_markup=save_btn)

@dp.callback_query(lambda c: c.data == "dork_save")
async def save_dork_results(callback: types.CallbackQuery):
    user_id = callback.from_user.id
    if user_id not in last_dork_results:
        await callback.answer("Нет результатов для сохранения", show_alert=True)
        return
    
    data = last_dork_results[user_id]
    filename = f"dork_results_{data['query']}_{datetime.now().strftime('%Y%m%d_%H%M%S')}.txt"
    
    with open(filename, "w", encoding="utf-8") as f:
        f.write(f"Google Dork Search Results\n")
        f.write(f"Query: {data['query']}\n")
        f.write(f"Type: {data['type']}\n")
        f.write(f"Date: {datetime.now().isoformat()}\n")
        f.write(f"\n{'='*50}\n\n")
        f.write("\n".join(data['results']))
        f.write(f"\n\n{'='*50}\n\n")
        f.write("Generated Dorks:\n")
        for d in data['dorks']:
            f.write(f"{d}\n")
    

    output += "━" * 40 + "\n\n"
    
    # Дані з номера
    if phone_results:
        output += f"📌 ЗА НОМЕРОМ:\n"
        for result in phone_results:
            for cell in result["data"]:
                cell_str = str(cell).strip()
                if re.match(r'[+]?\d{10,12}', cell_str):
                    output += f"├─ 📞 Телефон: {cell_str}\n"
                elif re.search(r'[А-ЯЁ][а-яё]+\s+[А-ЯЁ][а-яё]+', cell_str):

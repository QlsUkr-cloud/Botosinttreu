                    output += f"├─ 🌐 IP: {cell_str}\n"
                elif 'Авто' in cell_str or 'Toyota' in cell_str:
                    output += f"├─ 🚗 Авто: {cell_str}\n"
                elif re.match(r'^\d{12}$', cell_str):
                    output += f"├─ 🆔 ІІН: {cell_str}\n"
                elif 'паспорт' in cell_str.lower():
                    output += f"├─ 🪪 Паспорт: {cell_str}\n"
                elif 'вул.' in cell_str or 'м.' in cell_str:
                    output += f"├─ 🏠 Адреса: {cell_str}\n"
    
    return output


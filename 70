class DatabaseSearcher:
    def __init__(self, db_path):
        self.db_path = db_path
        self.databases = {}
        self.loaded = False
    
    def load_all_databases(self):
        """Завантаження всіх ТВОЇХ баз даних з папки database"""
        print("\n" + "=" * 60)
        print("📂 ЗАВАНТАЖЕННЯ ТВОЇХ БАЗ ДАНИХ")
        print("=" * 60)
        
        for country_name, file_name in COUNTRY_FILES.items():
            file_path = os.path.join(self.db_path, file_name)
            
            if os.path.exists(file_path):
                try:
                    data = []
                    # Читаємо файл (текстовий або CSV)
                    with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:
                        for line in f:
                            line = line.strip()
                            if line:
                                # Розбиваємо по табуляції або комі
                                if '\t' in line:
                                    parts = line.split('\t')
                                elif ',' in line:
                                    parts = line.split(',')
                                else:
                                    parts = [line]
                                data.append(parts)
                    
                    self.databases[country_name] = {
                        "file": file_name,
                        "data": data,
                        "records": len(data)
                    }
                    print(f"✅ {country_name} ({file_name}): {len(data)} записів")
                except Exception as e:
                    self.databases[country_name] = {"file": file_name, "data": [], "records": 0}
                    print(f"❌ {country_name}: помилка - {e}")
            else:
                self.databases[country_name] = {"file": file_name, "data": [], "records": 0}
                print(f"⚠️ {country_name}: файл '{file_name}' не знайдено")
        
        print("=" * 60)
        self.loaded = True
        return self.databases
    
    def search_in_file(self, query, country_name):
        """Пошук в конкретному файлі"""
        if not self.loaded:
            self.load_all_databases()
        
        if country_name not in self.databases:
            return []
        
        db = self.databases[country_name]
        query_clean = query.lower().strip()
        results = []
        
        for row in db["data"]:
            row_text = " ".join(str(cell) for cell in row).lower()
            if query_clean in row_text:
                results.append({"country": country_name, "data": row, "file": db["file"]})
        
        return results
    
    def search_phone(self, phone, country_name):
        """Пошук за номером телефону"""
        phone_clean = re.sub(r'\D', '', phone)
        
        if not self.loaded:
            self.load_all_databases()
        
        if country_name not in self.databases:
            return []
        
        db = self.databases[country_name]
        results = []
        
        for row in db["data"]:
            row_text = " ".join(str(cell) for cell in row)
            row_clean = re.sub(r'\D', '', row_text)
            if phone_clean in row_clean or row_clean.endswith(phone_clean[-7:]):
                results.append({"country": country_name, "data": row, "file": db["file"]})
        
        return results
    
    def search_fio(self, fio, country_name):
        """Пошук за ФІО"""
        fio_lower = fio.lower()
        
        if not self.loaded:
            self.load_all_databases()
        
        if country_name not in self.databases:
            return []
        
        db = self.databases[country_name]
        results = []
        
        for row in db["data"]:
            row_text = " ".join(str(cell) for cell in row).lower()
            if fio_lower in row_text:
                results.append({"country": country_name, "data": row, "file": db["file"]})
        
        return results


@dp.message(SearchStates.waiting_factcheck)
async def factcheck(message: types.Message, state: FSMContext):
    user_id = message.from_user.id
    text = message.text.strip()
    
    if len(text) < 10:
        await message.answer("❌ Занадто короткий текст")
        return
    
    await message.answer("🧠 Аналізую...")
    
    if not ai_enabled:
        await message.answer("❌ AI функції тимчасово недоступні")
    else:
        try:
            response = await openai_client.chat.completions.create(
                model="gpt-4o-mini",
                messages=[
                    {"role": "system", "content": "Ти експерт з перевірки фактів. Відповідай коротко українською."},
                    {"role": "user", "content": text}
                ],
                timeout=30
            )
            await message.answer(f"✅ Результат:\n\n{response.choices[0].message.content}")
        except Exception as e:
            await message.answer(f"❌ Помилка: {str(e)[:100]}")
    
    await state.clear()
    await message.answer(get_text(user_id, "main_menu"), reply_markup=get_main_menu(user_id))


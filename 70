        await message.answer(f"❌ Номер {phone} НЕ знайдено в базі {country}", reply_markup=get_main_menu(user_id))
        await state.clear()
        return
    
    # Отримуємо ФІО з результату
    fio = None
    for cell in phone_results[0]["data"]:
        cell_str = str(cell).strip()
        if re.search(r'[А-ЯЁ][а-яё]+\s+[А-ЯЁ][а-яё]+', cell_str):
            fio = cell_str
            break
    
    # Шукаємо за ФІО
    fio_results = []
    if fio:
        fio_results = await asyncio.to_thread(db_searcher.search_fio, fio, country)
    
    # Форматуємо результат
    formatted = format_recursive_result(phone_results, fio_results)
    
    # ШІ-аналіз
    if ai_enabled:
        await message.answer(get_text(user_id, "ai_analyze"))
        try:
            ai_response = await openai_client.chat.completions.create(
                model="gpt-4o-mini",
                messages=[
                    {"role": "system", "content": "Ти експерт з OSINT аналізу. Аналізуй знайдені дані коротко українською."},
                    {"role": "user", "content": f"Проаналізуй ці OSINT дані:\n{formatted}"}
                ],
                timeout=30
            )
            formatted += f"\n\n━" * 40 + f"\n\n🤖 ШІ-аналіз:\n{ai_response.choices[0].message.content}"
        except Exception as e:
            logging.error(f"AI помилка: {e}")
    
    await message.answer(formatted, reply_markup=get_main_menu(user_id))
    await state.clear()


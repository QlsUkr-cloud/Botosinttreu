async def recursive_search_by_country(message: types.Message, state: FSMContext):
    user_id = message.from_user.id
    country = message.text.strip()
    
    if country == get_text(user_id, "back"):
        await back_to_main(message, state)
        return
    
    data = await state.get_data()
    phone = data.get("recursive_phone")
    
    await message.answer(get_text(user_id, "searching"))
    
    # Шукаємо за номером

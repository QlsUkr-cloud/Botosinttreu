USERS_DB = "users.db"

def init_db():
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute('''CREATE TABLE IF NOT EXISTS users (
        user_id INTEGER PRIMARY KEY,
        language TEXT DEFAULT 'uk',
        promo_code TEXT,
        promo_expiry TEXT,
        search_count INTEGER DEFAULT 0
    )''')
    cursor.execute('''CREATE TABLE IF NOT EXISTS search_history (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER, query TEXT, query_type TEXT, 
        country TEXT, result_count INTEGER, search_date TEXT
    )''')
    conn.commit()
    conn.close()

init_db()

def get_user(user_id):
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute("SELECT language, promo_code, promo_expiry FROM users WHERE user_id = ?", (user_id,))
    r = cursor.fetchone()
    conn.close()
    return {"language": r[0], "promo_code": r[1], "promo_expiry": r[2]} if r else None

def save_user(user_id, lang="uk"):
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute("INSERT OR REPLACE INTO users (user_id, language, search_count) VALUES (?, ?, COALESCE((SELECT search_count FROM users WHERE user_id = ?), 0))", 
                   (user_id, lang, user_id))
    conn.commit()
    conn.close()

def update_promo(user_id, code):
    expiry = (datetime.now() + timedelta(days=30)).isoformat()
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute("UPDATE users SET promo_code = ?, promo_expiry = ? WHERE user_id = ?", (code, expiry, user_id))
    conn.commit()
    conn.close()

def check_promo(user_id):
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute("SELECT promo_expiry FROM users WHERE user_id = ?", (user_id,))
    r = cursor.fetchone()
    conn.close()
    if r and r[0]:
        return datetime.fromisoformat(r[0]) > datetime.now()
    return False

def add_history(user_id, query, qtype, country, count):
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute("INSERT INTO search_history (user_id, query, query_type, country, result_count, search_date) VALUES (?,?,?,?,?,?)",
                   (user_id, query, qtype, country, count, datetime.now().isoformat()))
    conn.commit()
    conn.close()

def inc_search(user_id):
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute("UPDATE users SET search_count = search_count + 1 WHERE user_id = ?", (user_id,))
    conn.commit()
    conn.close()


class FastSearcher:
    def __init__(self):
        self.index = {}
        self.loaded = False
    
    def load_all(self):
        """Завантажує бази або бере з кешу"""
        # Спроба завантажити з кешу
        if os.path.exists(INDEX_CACHE_FILE):
            try:
                with open(INDEX_CACHE_FILE, 'rb') as f:
                    cache_time = os.path.getmtime(INDEX_CACHE_FILE)
                    # Якщо кеш свіжіший за бази (останні 24 години)
                    if datetime.now().timestamp() - cache_time < 86400:
                        self.index = pickle.load(f)
                        self.loaded = True
                        print("✅ Завантажено з кешу!")
                        return
            except:
                pass
        
        # Якщо кешу немає - завантажуємо бази
        print("📂 Завантаження баз (це може зайняти час)...")
        for country_code in COUNTRIES:
            self.index[country_code] = {"phones": {}, "names": {}, "emails": [], "raw_count": 0}
            folder = os.path.join(DATABASES_DIR, country_code)
            if not os.path.exists(folder):
                continue
            
            for file in os.listdir(folder):
                if file.endswith(('.csv', '.txt')):
                    path = os.path.join(folder, file)
                    try:
                        with open(path, 'r', encoding='utf-8', errors='ignore') as f:
                            sample = f.read(1024)
                            f.seek(0)
                            delim = ';' if ';' in sample else ','
                            reader = csv.reader(f, delimiter=delim)
                            for row in reader:
                                if row:
                                    self.index[country_code]["raw_count"] += 1
                                    for cell in row:
                                        cell_str = str(cell).strip()
                                        # Телефони
                                        phone_clean = re.sub(r'\D', '', cell_str)
                                        if len(phone_clean) >= 7:
                                            if phone_clean not in self.index[country_code]["phones"]:
                                                self.index[country_code]["phones"][phone_clean] = []
                                            if len(self.index[country_code]["phones"][phone_clean]) < 20:
                                                self.index[country_code]["phones"][phone_clean].append(row)
                                        # Імена
                                        if re.match(r'[А-ЯЁІЇЄ][а-яёіїє]+\s+[А-ЯЁІЇЄ][а-яёіїє]+', cell_str):
                                            name_lower = cell_str.lower()
                                            if name_lower not in self.index[country_code]["names"]:
                                                self.index[country_code]["names"][name_lower] = []
                                            if len(self.index[country_code]["names"][name_lower]) < 20:
                                                self.index[country_code]["names"][name_lower].append(row)
                                        # Email
                                        if '@' in cell_str and '.' in cell_str:
                                            self.index[country_code]["emails"].append((cell_str.lower(), row))
                        print(f"   ✅ {country_code}: {file}")
                    except Exception as e:
                        print(f"   ❌ {file}: {e}")
        
        # Зберігаємо в кеш
        with open(INDEX_CACHE_FILE, 'wb') as f:
            pickle.dump(self.index, f)
        
        self.loaded = True
        print("✅ Бази завантажено та закешовано!")
    
    def search_phone(self, country, phone):
        if not self.loaded:
            self.load_all()
        phone_clean = re.sub(r'\D', '', phone)
        results = []
        # Точний збіг
        if phone_clean in self.index.get(country, {}).get("phones", {}):
            results.extend(self.index[country]["phones"][phone_clean])
        # Пошук по закінченню (тільки якщо не знайшли точний)
        if not results and len(phone_clean) >= 7:
            for p, rows in self.index.get(country, {}).get("phones", {}).items():
                if p.endswith(phone_clean[-7:]):
                    results.extend(rows)
                    if len(results) >= 30:
                        break
        return list({tuple(r) for r in results})[:50]
    
    def search_name(self, country, name):
        if not self.loaded:
            self.load_all()
        name_lower = name.lower().strip()
        results = []
        # Точний збіг
        if name_lower in self.index.get(country, {}).get("names", {}):
            results.extend(self.index[country]["names"][name_lower])
        # Частковий збіг
        if not results:
            for n, rows in self.index.get(country, {}).get("names", {}).items():
                if name_lower in n or all(p in n for p in name_lower.split()):
                    results.extend(rows)
                    if len(results) >= 30:
                        break
        return list({tuple(r) for r in results})[:50]
    
    def search_email(self, country, email):
        if not self.loaded:
            self.load_all()
        email_lower = email.lower()
        results = []
        for e, row in self.index.get(country, {}).get("emails", []):
            if email_lower in e or e == email_lower:
                results.append(row)
                if len(results) >= 30:
                    break
        return list({tuple(r) for r in results})[:50]
    
    def extract_info(self, country, rows):
        phones, names, emails, iin, addresses = set(), set(), set(), set(), set()
        for row in rows:
            for cell in row:
                cell_str = str(cell).strip()
                phone_clean = re.sub(r'\D', '', cell_str)
                if len(phone_clean) >= 7:
                    phones.add(phone_clean)
                if re.match(r'[А-ЯЁІЇЄ][а-яёіїє]+\s+[А-ЯЁІЇЄ][а-яёіїє]+', cell_str):
                    names.add(cell_str)
                if '@' in cell_str and '.' in cell_str:
                    emails.add(cell_str.lower())
                if re.match(r'^\d{10}$', cell_str) or re.match(r'^\d{12}$', cell_str):
                    iin.add(cell_str)
                if any(w in cell_str.lower() for w in ['вул', 'ул', 'просп', 'місто', 'город', 'село']):
                    addresses.add(cell_str)
        return {"phones": list(phones), "names": list(names), "emails": list(emails), "iin": list(iin), "addresses": list(addresses)}
    
    def deep_search(self, country, start_query, qtype="phone", max_depth=2):
        """Глибокий пошук (обмежений для швидкості)"""
        all_rows = []
        queue = [(start_query, qtype, 0)]
        processed = set()
        while queue and len(all_rows) < 100:
            query, qt, depth = queue.pop(0)
            if depth > max_depth:
                continue
            key = f"{qt}:{query}"
            if key in processed:
                continue
            processed.add(key)
            if qt == "phone":
                rows = self.search_phone(country, query)
            elif qt == "email":
                rows = self.search_email(country, query)
            else:
                rows = self.search_name(country, query)
            for row in rows:
                if tuple(row) not in all_rows:
                    all_rows.append(tuple(row))
            if depth < max_depth:
                info = self.extract_info(country, rows)
                for phone in info["phones"][:3]:
                    if f"phone:{phone}" not in processed:
                        queue.append((phone, "phone", depth + 1))
                for name in info["names"][:3]:
                    if f"name:{name}" not in processed:
                        queue.append((name, "name", depth + 1))
                for email in info["emails"][:2]:
                    if f"email:{email}" not in processed:
                        queue.append((email, "email", depth + 1))
        return {"total": len(all_rows), "rows": [list(r) for r in all_rows], "info": self.extract_info(country, all_rows)}


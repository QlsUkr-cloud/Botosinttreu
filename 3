@dp.message(InputStates.waiting_factcheck)
async def factcheck_analysis(message: types.Message, state: FSMContext):
    user_text = message.text.strip()
    
    if len(user_text) < 10:
        await message.answer("❌ **Слишком короткий текст.**", parse_mode="Markdown")
        return
    
    await message.answer("🧠 **Анализирую информацию...**", parse_mode="Markdown")
    
    try:
        response = await openai_client.chat.completions.create(
            model="gpt-4o-mini",
            messages=[
                {"role": "system", "content": "Ты — эксперт по проверке фактов. Отвечай на русском. Дай оценку: Правда / Неправда / Частично правда / Недостаточно данных. Напиши пояснение."},
                {"role": "user", "content": f"Проверь на достоверность: {user_text}"}
            ],
            temperature=0.3
        )
        
        analysis = response.choices[0].message.content
        await message.answer(f"✅ **Результат проверки:**\n\n{analysis}", parse_mode="Markdown")
        
    except Exception as e:
        await message.answer(f"❌ **Ошибка при анализе:** Проверь API ключ OpenAI.", parse_mode="Markdown")
    
    await state.clear()
    await message.answer("Что делаем дальше?", reply_markup=main_menu())


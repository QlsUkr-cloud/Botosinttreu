@dp.callback_query(lambda c: c.data.startswith("country_"))
async def process_country_selection(callback: types.CallbackQuery, state: FSMContext):
    country_code = callback.data.split("_")[1]
    
    country_names = {
        "kz": "Казахстан (ИИН)",
        "ru": "Россия (СНИЛС)",
        "ua": "Украина (РНОКПП)",
        "by": "Беларусь (УНП)"
    }
    
    instructions = {
        "kz": "Введи 12-значный ИИН. Пример: 920101350123",
        "ru": "Введи 11 цифр СНИЛС. Пример: 12345678901",
        "ua": "Введи 10 цифр ИНН. Пример: 1234567890",
        "by": "Введи 9 цифр УНП. Пример: 123456789"
    }
    
    await state.update_data(selected_country=country_code)
    await callback.message.edit_text(
        f"🆔 **Анализ {country_names[country_code]}**\n\n"
        f"{instructions[country_code]}\n\n"
        f"⚠️ *Показываю только техническую информацию.*",
        parse_mode="Markdown"
    )
    await state.set_state(InputStates.waiting_iin)
    await callback.answer()

@dp.message(InputStates.waiting_iin)
async def iin_analysis(message: types.Message, state: FSMContext):
    user_data = await state.get_data()
    country = user_data.get("selected_country", "kz")
    raw_input = message.text.strip().replace(" ", "").replace("-", "").replace("_", "")
    
    # Казахстан
    if country == "kz":
        if not re.match(r'^\d{12}$', raw_input):
            await message.answer("❌ Неверный формат ИИН. Нужно 12 цифр.")
            await state.clear()
            await message.answer("Что делаем дальше?", reply_markup=main_menu())
            return
        
        year_part = int(raw_input[0:2])
        month = int(raw_input[2:4])
        day = int(raw_input[4:6])
        century_code = int(raw_input[6])
        
        if century_code in [1, 2]:
            year = 1800 + year_part
        elif century_code in [3, 4]:
            year = 1900 + year_part
        elif century_code in [5, 6]:
            year = 2000 + year_part
        else:
            year = year_part
        
        gender = "Мужской" if century_code % 2 == 1 else "Женский"
        
        result = f"""
🆔 **Результат анализа ИИН (Казахстан)**

**ИИН:** `{raw_input}`
**📅 Дата рождения:** {day:02d}.{month:02d}.{year}
**🧑 Пол:** {gender}
"""
        await message.answer(result, parse_mode="Markdown")
    
    # Россия
    elif country == "ru":
        if not re.match(r'^\d{11}$', raw_input):
            await message.answer("❌ Неверный формат СНИЛС. Нужно 11 цифр.")
            await state.clear()
            await message.answer("Что делаем дальше?", reply_markup=main_menu())
            return
        
        result = f"""
🆔 **Результат анализа СНИЛС (Россия)**

**СНИЛС:** `{raw_input[:3]}-{raw_input[3:6]}-{raw_input[6:9]} {raw_input[9:11]}`

ℹ️ СНИЛС не содержит даты рождения или пола.
"""
        await message.answer(result, parse_mode="Markdown")
    
    # Украина
    elif country == "ua":
        if not re.match(r'^\d{10}$', raw_input):
            await message.answer("❌ Неверный формат ИНН. Нужно 10 цифр.")
            await state.clear()
            await message.answer("Что делаем дальше?", reply_markup=main_menu())
            return
        
        result = f"""
🆔 **Результат анализа ИНН (Украина)**

**ИНН/РНОКПП:** `{raw_input}`

ℹ️ ИНН не содержит публично расшифровываемых данных.
"""
        await message.answer(result, parse_mode="Markdown")
    
    # Беларусь
    elif country == "by":
        if not re.match(r'^\d{9}$', raw_input):
            await message.answer("❌ Неверный формат УНП. Нужно 9 цифр.")
            await state.clear()
            await message.answer("Что делаем дальше?", reply_markup=main_menu())
            return
        
        result = f"""
🆔 **Результат анализа УНП (Беларусь)**

**УНП:** `{raw_input[:2]}-{raw_input[2:5]}-{raw_input[5:9]}`

ℹ️ УНП — учётный номер плательщика.
"""
        await message.answer(result, parse_mode="Markdown")
    
    await state.clear()
    await message.answer("Что делаем дальше?", reply_markup=main_menu())


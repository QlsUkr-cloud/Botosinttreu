def format_extended_result(row) -> str:
    if not row:
        return None
    result = "📋 Знайдена інформація:\n\n"
    for cell in row:
        cell_str = str(cell).strip()
        if re.match(r'[+]?\d{10,12}', cell_str):
            result += f"📞 Телефон: {cell_str}\n"
            break
    for cell in row:
        cell_str = str(cell).strip()
        if re.match(r'[А-ЯЁ][а-яё]+\s+[А-ЯЁ][а-яё]+', cell_str):
            result += f"👤 ПІБ: {cell_str}\n"
            break
    return result


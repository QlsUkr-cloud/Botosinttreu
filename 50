    result += f"\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
    result += f"🔁 РЕКУРСИВНИЙ ПОШУК ЗА ФІО\n\n"
    
    if data.get("email"):
        result += f"├─ 📧 Email: {data['email']}\n"
    if data.get("telegram"):
        result += f"├─ 📱 Telegram: @{data['telegram']}\n"
    if data.get("tiktok"):
        result += f"├─ 🎵 TikTok: @{data['tiktok']}\n"
    if data.get("ip"):
        result += f"├─ 🌐 IP: {data['ip']}\n"
    if data.get("car"):
        result += f"├─ 🚗 Авто: {data['car']}\n"

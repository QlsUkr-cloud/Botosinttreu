# ==================== ЗМІНА МОВИ ====================
@dp.callback_query(lambda c: c.data.startswith("lang_"))
async def change_language(callback: types.CallbackQuery):
    user_id = callback.from_user.id
    lang = callback.data.split("_")[1]
    save_user_lang(user_id, lang)
    await callback.message.edit_text(get_text(user_id, "main_menu"))
    await callback.message.answer(get_text(user_id, "main_menu"), reply_markup=get_main_menu(user_id))
    await callback.answer()

@dp.message(F.text == "🌍 Змінити мову")
async def change_lang_menu(message: types.Message):
    await message.answer("Оберіть мову / Выберите язык / Choose language:", reply_markup=lang_menu)

@dp.message(F.text == "◀️ Назад")
async def back_to_main(message: types.Message, state: FSMContext):
    user_id = message.from_user.id
    await state.clear()
    await message.answer(get_text(user_id, "main_menu"), reply_markup=get_main_menu(user_id))

# ==================== ВИБІР БАЗИ ====================
async def ask_country(message: types.Message, state: FSMContext, search_type: str, value: str):
    user_id = message.from_user.id
    await state.update_data(search_type=search_type, search_value=value)
    await message.answer(get_text(user_id, "choose_base"), reply_markup=get_country_menu(user_id))
    await state.set_state(SearchStates.waiting_country)

@dp.message(SearchStates.waiting_country)
async def process_country(message: types.Message, state: FSMContext):
    user_id = message.from_user.id
    if message.text == get_text(user_id, "back"):
        await back_to_main(message, state)
        return
    data = await state.get_data()
    result = f"🔍 {get_text(user_id, 'found')}\n📋 Тип: {data.get('search_type')}\n🔎 Запит: {data.get('search_value')}\n🗄️ База: {message.text}\n\n(заглушка - реальний пошук потребує API)"
    await message.answer(result, reply_markup=get_main_menu(user_id))
    await state.clear()


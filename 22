def format_simple_result():
    return "✅ Знайдено в базі даних!"

def format_extended_result(row):
    if not row:
        return None
    
    result = "📋 Розширена інформація:\n\n"
    
    phone_pattern = r'[+]?\d{10,12}'
    for cell in row:
        cell_str = str(cell).strip()
        if not cell_str:
            continue
        if re.match(phone_pattern, cell_str):
            result += f"📞 Телефон: {cell_str}\n"
            break
    
    name_pattern = r'[А-ЯЁ][а-яё]+\s+[А-ЯЁ][а-яё]+(?:\s+[А-ЯЁ][а-яё]+)?'
    for cell in row:
        cell_str = str(cell).strip()
        if re.match(name_pattern, cell_str):
            result += f"👤 ПІБ: {cell_str}\n"
            break
    
    region_pattern = r'[А-ЯЁ][а-яё]+(?:[-\s][А-ЯЁ][а-яё]+)?(?:AO|край|область|район)'
    for cell in row:
        cell_str = str(cell).strip()
        if re.search(region_pattern, cell_str, re.IGNORECASE):
            result += f"📍 Регіон: {cell_str}\n"
            break
    
    date_pattern = r'\d{2}[./]\d{2}[./]\d{4}'
    for cell in row:
        cell_str = str(cell).strip()
        if re.match(date_pattern, cell_str):
            result += f"📅 Дата: {cell_str}\n"
            break
    
    other_info = []
    for cell in row:
        cell_str = str(cell).strip()
        if cell_str and not any(x in result for x in cell_str):
            if len(cell_str) < 50 and not re.match(phone_pattern, cell_str):
                other_info.append(cell_str)
    
    if other_info:
        result += f"ℹ️ Додатково: {', '.join(other_info[:3])}\n"
    
    return result


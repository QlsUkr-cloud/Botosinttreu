WHITELIST_FILE = "whitelist.json"
PROMOCODES_FILE = "promocodes.json"

def load_whitelist():
    if os.path.exists(WHITELIST_FILE):
        with open(WHITELIST_FILE, "r", encoding='utf-8') as f:
            return json.load(f)
    return {}

def save_whitelist(whitelist):
    with open(WHITELIST_FILE, "w", encoding='utf-8') as f:
        json.dump(whitelist, f, indent=2, ensure_ascii=False)

def load_promocodes():
    if os.path.exists(PROMOCODES_FILE):
        with open(PROMOCODES_FILE, "r", encoding='utf-8') as f:
            return json.load(f)
    promocodes = {}
    for i in range(30):
        code = secrets.token_hex(5).upper()
        promocodes[code] = {"used": False, "used_by": None, "user_data": None}
    save_promocodes(promocodes)
    return promocodes

def save_promocodes(promocodes):
    with open(PROMOCODES_FILE, "w", encoding='utf-8') as f:
        json.dump(promocodes, f, indent=2, ensure_ascii=False)

whitelist = load_whitelist()
promocodes = load_promocodes()

def is_whitelisted(username=None, phone=None, user_id=None):
    for entry in whitelist.values():
        if username and entry.get("username") == username:
            return True
        if phone and entry.get("phone") == phone:
            return True
        if user_id and entry.get("user_id") == user_id:
            return True
    return False

def add_to_whitelist(user_id, username, phone, promo_code):
    whitelist[str(user_id)] = {
        "user_id": user_id,
        "username": username,
        "phone": phone,
        "added_at": datetime.now().isoformat(),
        "promo_code": promo_code
    }
    save_whitelist(whitelist)

# =============== КЛАС ДЛЯ ПОШУКУ ===============
class DatabaseSearcher:
    def __init__(self, db_path):
        self.db_path = db_path
        self.databases_info = {}
        self.loaded = False
        self.all_data = []
    
    def scan_databases(self):
        if not os.path.exists(self.db_path):
            os.makedirs(self.db_path)
            return {}
        
        databases = {}
        files = []
        
        for ext in ['*.csv', '*.txt', '*.xlsx']:
            files.extend(glob.glob(os.path.join(self.db_path, ext)))
        
        for file_path in files:
            file_name = os.path.basename(file_path)
            try:
                file_size = os.path.getsize(file_path)
                size_mb = file_size / (1024 * 1024)
                
                databases[file_name] = {
                    'path': file_path,
                    'size_mb': round(size_mb, 2),
                    'type': file_path.split('.')[-1]
                }
                print(f"📁 Знайдено: {file_name}")
            except Exception as e:
                print(f"❌ Помилка: {e}")
        
        self.databases_info = databases
        self.loaded = True
        return databases
    
    def load_all_data(self):
        if not self.loaded:
            self.scan_databases()
        
        self.all_data = []
        
        for name, info in self.databases_info.items():
            try:
                with open(info['path'], 'r', encoding='utf-8', errors='ignore') as f:
                    sample = f.read(1024)
                    f.seek(0)
                    delimiter = ';' if ';' in sample else ','
                    reader = csv.reader(f, delimiter=delimiter)
                    
                    for row in reader:
                        if row and len(row) > 0:
                            self.all_data.append(row)
                print(f"✅ Завантажено: {name}")
            except Exception as e:
                print(f"❌ Помилка {name}: {e}")
        
        return self.all_data
    
    def search_phone(self, phone_number):
        if not self.all_data:
            self.load_all_data()
        
        phone_clean = re.sub(r'\D', '', phone_number)
        results = []
        
        for row in self.all_data:
            row_text = " ".join(row)
            row_clean = re.sub(r'\D', '', row_text)
            
            if phone_clean in row_clean or row_clean.endswith(phone_clean[-7:]):
                results.append(row)
        
        unique_results = []
        for r in results:
            if r not in unique_results:
                unique_results.append(r)
        
        return unique_results
    
    def search_name(self, name_query):
        if not self.all_data:
            self.load_all_data()
        
        name_lower = name_query.lower()
        results = []
        
        for row in self.all_data:
            row_text = " ".join(row).lower()
            if name_lower in row_text:
                results.append(row)
        
        unique_results = []
        for r in results:
            if r not in unique_results:
                unique_results.append(r)
        
        return unique_results


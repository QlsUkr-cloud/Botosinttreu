    cursor.execute("SELECT level, used_by FROM promocodes WHERE code = ?", (code,))
    promo = cursor.fetchone()
    conn.close()
    
    if not promo:
        await message.answer(get_text(user_id, "promo_invalid"))
    elif promo[1] is not None:
        await message.answer(get_text(user_id, "promo_already_used"))
    else:
        level = promo[0]
        activate_promo(user_id, code, level)
        await message.answer(get_text(user_id, "promo_activated") + f"\n📅 Рівень: {level}\n📅 Дійсний 30 днів")
        
        if next_action:
            await state.update_data(country=country)
            if next_action == "email":
                await message.answer(get_text(user_id, "enter_email"))
                await state.set_state(States.waiting_email)
            elif next_action == "tg":
                await message.answer(get_text(user_id, "enter_tg"))
                await state.set_state(States.waiting_tg)
            elif next_action == "address":
                await message.answer(get_text(user_id, "enter_address"))
                await state.set_state(States.waiting_address)
            elif next_action == "tiktok":
                await message.answer(get_text(user_id, "enter_tiktok"))

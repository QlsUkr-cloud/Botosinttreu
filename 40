async def perform_search(message: types.Message, state: States, search_type: str):
    user_id = message.from_user.id
    query = message.text.strip()
    data = await state.get_data()
    country = data.get("country")
    deep_mode = data.get("deep_mode", False)
    
    if not country:
        await message.answer(get_text(user_id, "main_menu"), reply_markup=country_keyboard(user_id))
        await state.clear()
        return
    
    if deep_mode:
        await message.answer(get_text(user_id, "deep_analyzing"))
        
        result = await asyncio.to_thread(searcher.deep_osint_analysis, country, query, search_type, 2)
        inc_search(user_id)
        add_history(user_id, query, "deep", country, result.get("total_records", 0))
        
        stats = None
        conn = sqlite3.connect(STATS_DB)
        cursor = conn.cursor()
        cursor.execute("SELECT search_count, last_searched FROM search_stats WHERE query = ?", (query,))
        r = cursor.fetchone()
        conn.close()
        stats_text = f"{r[0]}, {datetime.fromisoformat(r[1]).strftime('%d.%m.%Y %H:%M')}" if r else "вперше"
        
        result_text = get_text(user_id, "analysis_result",
            total_records=result.get("total_records", 0),
            phones=result.get("phones", []),
            names=result.get("names", []),
            nicknames=result.get("nicknames", []),
            emails=result.get("emails", []),
            iin=result.get("iin", []),
            addresses=result.get("addresses", []),
            tg_usernames=result.get("tg_usernames", []),
            tiktok=result.get("tiktok", []),
            ip=result.get("ip", []),
            auto=result.get("auto", []),
            vk=result.get("vk", []),
            cards=result.get("cards", []),
            jobs=result.get("jobs", []),
            relatives=result.get("relatives", []),
            dates=result.get("dates", []),
            stats_count=stats_text,
            stats_last=""
        )
        
        if len(result_text) > 4000:
            for i in range(0, len(result_text), 4000):
                await message.answer(result_text[i:i+4000])
        else:
            await message.answer(result_text)
    else:
        await message.answer(get_text(user_id, "searching"))
        
        results = await asyncio.to_thread(searcher.search_in_files, country, query, search_type)
        inc_search(user_id)
        add_history(user_id, query, search_type, country, len(results))
        
        if results:
            await message.answer(get_text(user_id, "found", count=len(results)))
            for row in results[:10]:
                row_text = " | ".join(str(cell) for cell in row if cell)
                if len(row_text) > 500:
                    row_text = row_text[:500] + "..."
                await message.answer(f"📋 {row_text}")
            if len(results) > 10:
                await message.answer(f"📊 Показано 10 з {len(results)} результатів")
        else:
            await message.answer(get_text(user_id, "not_found"))
    
    await state.clear()
    await message.answer(get_text(user_id, "main_menu"), reply_markup=country_keyboard(user_id))


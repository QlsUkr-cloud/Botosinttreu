                unique.append(r)
        return unique
    
    def deep_osint_analysis(self, country_code, query, query_type="phone", max_depth=3):
        all_rows = []
        queue = [(query, query_type, 0)]
        processed = set()
        
        while queue and len(all_rows) < 200:
            q, qtype, depth = queue.pop(0)
            if depth > max_depth:
                continue
            
            key = f"{qtype}:{q}"
            if key in processed:
                continue
            processed.add(key)
            
            rows = self.search_in_files(country_code, q, qtype)
            
            for row in rows:
                if tuple(row) not in all_rows:
                    all_rows.append(tuple(row))
            
            if depth < max_depth:
                data = self.extract_all_data(rows)
                
                for phone in data["phones"][:3]:
                    if f"phone:{phone}" not in processed:
                        queue.append((phone, "phone", depth + 1))
                for name in data["names"][:3]:
                    if f"name:{name}" not in processed:
                        queue.append((name, "name", depth + 1))
                for email in data["emails"][:2]:
                    if f"email:{email}" not in processed:
                        queue.append((email, "email", depth + 1))
                for tg in data["tg_usernames"][:2]:
                    if f"tg:{tg}" not in processed:
                        queue.append((tg, "tg", depth + 1))
        
        final_data = self.extract_all_data(all_rows)
        final_data["total_records"] = len(all_rows)
        
        return final_data


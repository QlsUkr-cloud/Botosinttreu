def format_recursive_result(record):
    """Форматування рекурсивного результату"""
    if not record:
        return None
    
    result = "🔍 РЕЗУЛЬТАТИ ПОШУКУ\n"
    result += "━" * 40 + "\n\n"
    
    result += f"📌 ЗА НОМЕРОМ: {record.get('phone', 'Не вказано')}\n"
    result += f"├─ 📞 Телефон: {record.get('phone', 'Не вказано')}\n"
    result += f"├─ 👤 ФІО: {record.get('fio', 'Не вказано')}\n"
    
    if record.get('also'):
        result += f"├─ 👥 Також: {record.get('also')}\n"
    if record.get('region'):
        result += f"├─ 📍 Регіон: {record.get('region')}\n"
    if record.get('date'):
        result += f"├─ 📅 Дата: {record.get('date')}\n"
    if record.get('operator'):
        result += f"└─ 🏦 Оператор: {record.get('operator')}\n"
    
    result += f"\n" + "━" * 40 + "\n\n"
    result += f"🔁 РЕКУРСИВНИЙ ПОШУК ЗА ФІО\n\n"
    
    if record.get('email'):
        result += f"├─ 📧 Email: {record.get('email')}\n"
    if record.get('telegram'):
        result += f"├─ 📱 Telegram: {record.get('telegram')}\n"
    if record.get('tiktok'):
        result += f"├─ 🎵 TikTok: {record.get('tiktok')}\n"
    if record.get('ip'):
        result += f"├─ 🌐 IP: {record.get('ip')}\n"
    if record.get('car'):
        result += f"├─ 🚗 Авто: {record.get('car')}\n"
    if record.get('iin'):
        result += f"├─ 🆔 ІІН: {record.get('iin')}\n"
    if record.get('passport'):
        result += f"├─ 🪪 Паспорт РФ: {record.get('passport')}\n"
    if record.get('address'):
        result += f"├─ 🏠 Адреса: {record.get('address')}\n"
    if record.get('card'):
        result += f"└─ 💳 Карти: {record.get('card')}\n"
    
    return result


    if not phone_results:
        await message.answer(get_text(user_id, "not_found"), reply_markup=get_main_menu(user_id))
        await state.clear()
        return
    
    # Беремо перший результат
    record = phone_results[0]
    
    # Шукаємо додаткову інформацію за ФІО
    fio = record.get('fio', '')
    if fio:
        fio_results = await asyncio.to_thread(db_searcher.search_fio, fio)
        if fio_results:
            # Об'єднуємо дані
            for extra in fio_results:
                for key, value in extra.items():
                    if value and not record.get(key):
                        record[key] = value
    
    result = format_recursive_result(record)
    
    # ШІ-аналіз
    if ai_enabled:
        await message.answer(get_text(user_id, "ai_analyze"))
        try:
            ai_response = await openai_client.chat.completions.create(
                model="gpt-4o-mini",
                messages=[
                    {"role": "system", "content": "Ти експерт з OSINT аналізу. Аналізуй знайдені дані та знаходь зв'язки. Відповідай коротко українською."},
                    {"role": "user", "content": f"Проаналізуй ці OSINT дані та напиши короткий висновок (зв'язки, ризики, рекомендації):\n{result}"}
                ],
                timeout=30
            )
            ai_analysis = f"\n\n━" * 40 + "\n\n🤖 ШТУЧНИЙ ІНТЕЛЕКТ (АНАЛІЗ)\n\n{ai_response.choices[0].message.content}"
            result += ai_analysis
        except Exception as e:
            logging.error(f"AI помилка: {e}")
    
    await message.answer(result, reply_markup=get_main_menu(user_id))
    await state.clear()


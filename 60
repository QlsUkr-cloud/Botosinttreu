class DatabaseSearcher:
    def __init__(self, db_file):
        self.db_file = db_file
        self.data = []
        self.headers = []
        self.loaded = False
    
    def load_data(self):
        """Завантаження даних з CSV файлу"""
        self.data = []
        try:
            with open(self.db_file, 'r', encoding='utf-8') as f:
                reader = csv.reader(f)
                self.headers = next(reader)  # читаємо заголовки
                for row in reader:
                    if row and len(row) >= len(self.headers):
                        # Створюємо словник для зручного доступу
                        record = {}
                        for i, header in enumerate(self.headers):
                            if i < len(row):
                                record[header] = row[i]
                            else:
                                record[header] = ""
                        self.data.append(record)
            print(f"✅ Завантажено {len(self.data)} записів з {self.db_file}")
        except Exception as e:
            print(f"❌ Помилка завантаження бази: {e}")
        
        self.loaded = True
        return self.data
    
    def search_phone(self, phone_number):
        """Пошук за номером телефону (точний збіг)"""
        if not self.loaded:
            self.load_data()
        
        phone_clean = re.sub(r'\D', '', phone_number)
        results = []
        
        for record in self.data:
            record_phone = re.sub(r'\D', '', record.get('phone', ''))
            if record_phone == phone_clean or phone_clean in record_phone:
                results.append(record)
        
        return results
    
    def search_fio(self, fio_query):
        """Пошук за ФІО"""
        if not self.loaded:
            self.load_data()
        
        fio_lower = fio_query.lower()
        results = []
        
        for record in self.data:
            record_fio = record.get('fio', '').lower()
            if fio_lower in record_fio:
                results.append(record)
        
        return results
    
    def get_all_data(self):
        """Отримати всі дані"""
        if not self.loaded:
            self.load_data()
        return self.data


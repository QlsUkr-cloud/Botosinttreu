@dp.message(Command("gen_promo"))
async def gen_promo(message: types.Message):
    if message.from_user.id != OWNER_ID:
        await message.answer("❌ Доступ заборонено")
        return
    
    code = secrets.token_hex(4).upper()
    promocodes[code] = {"used": False, "used_by": None}
    save_promocodes(promocodes)
    await message.answer(f"✅ Новий промокод: `{code}`\nВсього промокодів: {len(promocodes)}")

@dp.message(Command("list_promo"))
async def list_promo(message: types.Message):
    if message.from_user.id != OWNER_ID:
        await message.answer("❌ Доступ заборонено")
        return
    
    used = [f"`{k}` - використав {v['used_by']}" for k, v in promocodes.items() if v["used"]]
    unused = [f"`{k}`" for k, v in promocodes.items() if not v["used"]]
    
    result = "📋 **Промокоди:**\n\n"
    result += f"✅ Використані ({len(used)}):\n" + ("\n".join(used) if used else "Немає") + "\n\n"
    result += f"🟢 Не використані ({len(unused)}):\n" + ("\n".join(unused[:20]) if unused else "Немає")
    
    await message.answer(result[:4000])


# =============== ПОШУКОВІ ФУНКЦІЇ ===============
def search_by_fio(query):
    query_lower = query.lower()
    for name, data in FAKE_DATA["fio"].items():
        if query_lower in name:
            return {"name": name.title(), **data}
    return None

def search_by_gmail(query):
    query_lower = query.lower()
    for email, data in FAKE_DATA["gmail"].items():
        if query_lower in email:
            return {"email": email, **data}
    return None

def search_by_passport(query):
    query_upper = query.upper()
    for passport, data in FAKE_DATA["passport"].items():
        if query_upper == passport.upper() or query_upper in passport.upper():
            return {"passport": passport, **data}
    return None

def search_by_card(query):
    query_clean = re.sub(r'\D', '', query)
    for card, data in FAKE_DATA["cards"].items():
        if query_clean == card or query_clean in card or card.endswith(query_clean[-4:]):
            return {"card": card, **data}
    return None


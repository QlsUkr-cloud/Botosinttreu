class DatabaseSearcher:
    def __init__(self):
        self.file_cache = {}
    
    def get_files_for_country(self, country_code):
        folder = os.path.join(DATABASES_DIR, country_code)
        if not os.path.exists(folder):
            return []
        files = []
        for item in os.listdir(folder):
            item_path = os.path.join(folder, item)
            if os.path.isfile(item_path):
                if item in ['.DS_Store', 'Thumbs.db', 'desktop.ini']:
                    continue
                files.append(item_path)
        return files
    
    def search_in_file(self, file_path, query, search_type="phone"):
        results = []
        try:
            cache_key = f"{file_path}:{query}:{search_type}"
            if cache_key in self.file_cache:
                return self.file_cache[cache_key]
            
            with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:
                lines = f.readlines()
                
                query_clean = re.sub(r'\D', '', query) if search_type == "phone" else query.lower()
                if search_type == "tg" and query.startswith('@'):
                    query_clean = query[1:].lower()
                
                for line in lines:
                    line = line.strip()
                    if not line:
                        continue
                    
                    if '|' in line:
                        cells = line.split('|')
                    elif ',' in line:
                        cells = line.split(',')
                    elif ';' in line:
                        cells = line.split(';')
                    elif '\t' in line:
                        cells = line.split('\t')
                    else:
                        cells = [line]
                    
                    if search_type == "phone":
                        for cell in cells:
                            cell_clean = re.sub(r'\D', '', str(cell))
                            if cell_clean and (cell_clean == query_clean or (len(cell_clean) >= 7 and cell_clean.endswith(query_clean[-7:]))):
                                results.append(cells)
                                break
                    elif search_type == "iin":
                        for cell in cells:
                            cell_clean = re.sub(r'\D', '', str(cell))
                            if len(cell_clean) == 12 and cell_clean == query_clean:
                                results.append(cells)
                                break
                    else:
                        line_lower = line.lower()
                        if query_clean in line_lower:
                            results.append(cells)
                    
                    if len(results) >= 50:
                        break
            
            self.file_cache[cache_key] = results
            return results
        except Exception as e:
            print(f"❌ Помилка {file_path}: {str(e)[:100]}")
            return []
    
    def search_country(self, country_code, query, search_type="phone"):
        files = self.get_files_for_country(country_code)
        all_results = []
        
        for file_path in files:
            results = self.search_in_file(file_path, query, search_type)
            if results:
                all_results.extend(results)
            if len(all_results) >= 50:
                break
        
        unique = []
        for r in all_results:
            if r not in unique:
                unique.append(r)
        
        return unique[:50]
    
    def analyze_iin(self, iin):
        if not re.match(r'^\d{12}$', iin):
            return None
        
        century = int(iin[6])
        if century in [3, 4]:
            year = 1900 + int(iin[0:2])
        else:
            year = 2000 + int(iin[0:2])
        
        month = int(iin[2:4])
        day = int(iin[4:6])
        gender = "Чоловіча" if century % 2 == 1 else "Жіноча"
        
        region_codes = {
            "1": "м. Астана", "2": "м. Алмати", "3": "Акмолинская", "4": "Актюбинская",
            "5": "Алматинская", "6": "Атырауская", "7": "Западно-Казахстанская"
        }
        region = region_codes.get(iin[:2], "Казахстан")
        
        extra_data = []
        results = self.search_country("kz", iin, "iin")
        for row in results[:3]:
            for cell in row:
                cell_str = str(cell).strip()
                if re.match(r'[+]?\d{10,12}', cell_str):
                    extra_data.append(f"📞 Телефон: {cell_str}")
                elif '@' in cell_str:
                    extra_data.append(f"📧 Email: {cell_str}")
                elif cell_str.startswith('@'):
                    extra_data.append(f"📱 Telegram: {cell_str}")
        
        return {
            "iin": iin,
            "birth_date": f"{day:02d}.{month:02d}.{year}",
            "gender": gender,
            "region": region,
            "extra": "\n".join(extra_data) if extra_data else "Немає додаткових даних"
        }
    
    def format_results(self, results, search_type="phone"):
        if not results:
            return None
        
        phones, names, emails, tg, vk, addresses, dates, orders, cards = set(), set(), set(), set(), set(), set(), set(), [], []
        
        for row in results:
            for cell in row:
                cell_str = str(cell).strip()
                
                phone_clean = re.sub(r'\D', '', cell_str)
                if len(phone_clean) >= 10 and len(phone_clean) <= 12:
                    phones.add(phone_clean)
                
                if re.search(r'[А-ЯЁІЇЄ][а-яёіїє]+\s+[А-ЯЁІЇЄ][а-яёіїє]+', cell_str):
                    names.add(cell_str)
                
                if '@' in cell_str and '.' in cell_str:
                    emails.add(cell_str.lower())
                
                if cell_str.startswith('@'):
                    tg.add(cell_str)
                
                if 'vk.com' in cell_str.lower() or cell_str.startswith('id'):
                    vk.add(cell_str)
                
                if any(w in cell_str.lower() for w in ['вул', 'ул', 'просп', 'місто', 'город']):
                    addresses.add(cell_str)
                
                if re.match(r'\d{2}[./]\d{2}[./]\d{4}', cell_str):
                    dates.add(cell_str)
                
                if search_type == "yandex_eda" and '|' in str(row):
                    if len(row) >= 6:
                        orders.append({"phone": row[0], "name": row[1], "address": row[2], "date": row[3], "amount": row[4], "items": row[5]})
                
                if search_type == "mts_bank" and '|' in str(row):
                    if len(row) >= 5:
                        cards.append({"phone": row[0], "name": row[1], "card": row[2], "expiry": row[3], "balance": row[4]})
        
        return {
            "phones": list(phones)[:10],
            "names": list(names)[:10],
            "emails": list(emails)[:5],
            "tg": list(tg)[:5],
            "vk": list(vk)[:5],
            "addresses": list(addresses)[:5],
            "dates": list(dates)[:10],
            "orders": orders[:10],
            "cards": cards[:10]
        }


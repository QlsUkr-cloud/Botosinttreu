@dp.callback_query(lambda c: c.data in ["continue_yes", "continue_no"])
async def handle_continue(callback: types.CallbackQuery, state: States):
    user_id = callback.from_user.id
    data = await state.get_data()
    
    if callback.data == "continue_yes":
        query = data.get("last_query")
        country = data.get("last_country")
        search_type = data.get("last_search_type")
        if query and country:
            await callback.message.answer(get_text(user_id, "searching", query=query, country=COUNTRIES.get(country, country)))
            results = await asyncio.to_thread(searcher.search_country, country, query, search_type)
            await process_search_results(callback.message, user_id, results, query, country, search_type, state)
    else:
        await state.clear()
        await callback.message.answer(get_text(user_id, "main_menu"), reply_markup=country_keyboard(user_id))
    
    await callback.answer()

async def process_search_results(message, user_id, results, query, country, search_type, state):
    country_name = COUNTRIES.get(country, country)
    
    if not results:
        await message.answer(get_text(user_id, "not_found"))
        await message.answer(get_text(user_id, "main_menu"), reply_markup=country_keyboard(user_id))
        return
    
    inc_search(user_id)
    add_history(user_id, query, search_type, country, len(results))
    
    if search_type == "yandex_eda":
        formatted_data = searcher.format_results(results, "yandex_eda")
        result_text = format_yandex_result(formatted_data["orders"], query, country_name)
    elif search_type == "mts_bank":
        formatted_data = searcher.format_results(results, "mts_bank")
        result_text = format_mts_result(formatted_data["cards"], query)
    elif search_type == "mvd":
        result_text = format_mvd_result(results, query)
    else:
        formatted_data = searcher.format_results(results, search_type)
        result_text = format_main_result(formatted_data, query, country_name)
    
    await message.answer(result_text[:4000])
    
    if ai_enabled:
        await message.answer(get_text(user_id, "ai_analyze"))
        ai_result = await ai_analysis(user_id, result_text[:3000])
        await message.answer(ai_result)
    
    await state.update_data(last_query=query, last_country=country, last_search_type=search_type)
    await message.answer(get_text(user_id, "continue_search"), reply_markup=continue_keyboard(user_id))
    await state.set_state(States.waiting_continue)


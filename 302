        "mts": get_text(user_id, "enter_mts"),
        "mvd": get_text(user_id, "enter_mvd")
    }
    
    if action in prompts:
        await callback.message.edit_text(prompts[action])
        await state.set_state(getattr(States, f"waiting_{action}", States.waiting_phone))
        await state.update_data(search_type=action)

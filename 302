def format_main_result(data, query, country_name):
    result = f"🔍 РЕЗУЛЬТАТИ ПОШУКУ\n"
    result += "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
    result += f"📌 База: {country_name}\n"
    result += f"📌 Запит: {query}\n\n"
    result += "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
    
    if data["names"]:
        result += f"👤 ОСНОВНА ОСОБА: {data['names'][0]}\n\n"
    
    if data["phones"]:
        result += "📞 ТЕЛЕФОНИ:\n"
        for i, phone in enumerate(data["phones"]):
            prefix = "├─" if i < len(data["phones"]) - 1 else "└─"
            result += f"{prefix} {phone}\n"
        result += "\n"
    
    if data["emails"]:
        result += "📧 EMAIL:\n"
        for i, email in enumerate(data["emails"]):
            prefix = "├─" if i < len(data["emails"]) - 1 else "└─"
            result += f"{prefix} {email}\n"
        result += "\n"
    
    if data["tg"]:
        result += "📱 TELEGRAM:\n"
        for i, tg in enumerate(data["tg"]):
            prefix = "├─" if i < len(data["tg"]) - 1 else "└─"
            result += f"{prefix} {tg}\n"
        result += "\n"
    
    if data["vk"]:
        result += "🎥 VK:\n"
        for i, vk in enumerate(data["vk"]):
            prefix = "├─" if i < len(data["vk"]) - 1 else "└─"
            result += f"{prefix} {vk}\n"
        result += "\n"
    
    if data["addresses"]:
        result += "📍 АДРЕСИ:\n"
        for i, addr in enumerate(data["addresses"]):
            prefix = "├─" if i < len(data["addresses"]) - 1 else "└─"
            result += f"{prefix} {addr}\n"
        result += "\n"
    
    if data["dates"]:
        result += "📅 ДАТИ:\n"
        for i, date in enumerate(data["dates"][:5]):
            prefix = "├─" if i < len(data["dates"][:5]) - 1 else "└─"
            result += f"{prefix} {date}\n"
        result += "\n"
    
    return result

def format_yandex_result(orders, query, country_name):
    if not orders:
        return None
    
    result = f"🍔 РЕЗУЛЬТАТИ ПОШУКУ (ЯНДЕКС ЕДА)\n"
    result += "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
    result += f"📌 Запит: {query}\n\n"
    
    total_amount = 0
    for i, order in enumerate(orders, 1):
        result += f"📋 ЗАМОВЛЕННЯ №{i}:\n"
        result += f"├─ 📞 Телефон: {order.get('phone', '❌')}\n"
        result += f"├─ 👤 ПІБ: {order.get('name', '❌')}\n"
        result += f"├─ 🏠 Адреса: {order.get('address', '❌')}\n"
        result += f"├─ 📅 Дата: {order.get('date', '❌')}\n"
        result += f"├─ 💰 Сума: {order.get('amount', '0')} руб\n"
        result += f"└─ 🍽 Страви: {order.get('items', '❌')}\n\n"
        try:
            total_amount += int(order.get('amount', '0'))
        except:
            pass
    
    result += "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n"
    result += f"💰 СУМАРНО: {len(orders)} замовлень на {total_amount} руб\n"
    
    if orders and orders[0].get('address'):
        result += f"🏠 Адреса доставки: {orders[0]['address']}\n"
    
    return result

def format_mvd_result(results, query):
    result = f"🏛 РЕЗУЛЬТАТИ ПОШУКУ (МВД)\n"
    result += "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
    result += f"📌 Запит: {query}\n\n"
    
    for row in results[:5]:
        if len(row) >= 4:
            result += f"📋 ІНФОРМАЦІЯ ПРО ОСОБУ:\n"
            result += f"├─ 👤 ПІБ: {row[1] if len(row) > 1 else '❌'}\n"
            result += f"├─ 📅 Дата народження: {row[2] if len(row) > 2 else '❌'}\n"
            result += f"├─ 🆔 Паспорт: {row[0]}\n"
            status = "✅ Не в розшуку" if "не в розшуку" in row[3].lower() else f"⚠️ {row[3]}"
            result += f"└─ ⚠️ Статус: {status}\n"
            if len(row) > 4 and row[4]:
                result += f"   📋 Стаття: {row[4]}\n"
            result += "\n"
    
    return result

def format_mts_result(cards, query):
    if not cards:
        return None
    
    result = f"🏦 РЕЗУЛЬТАТИ ПОШУКУ (МТС БАНК)\n"
    result += "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
    result += f"📌 Запит: {query}\n\n"
    
    for card in cards[:5]:
        result += f"📋 КАРТА:\n"
        result += f"├─ 👤 ПІБ: {card.get('name', '❌')}\n"
        result += f"├─ 📞 Телефон: {card.get('phone', '❌')}\n"
        result += f"├─ 💳 Карта: {card.get('card', '❌')}\n"
        result += f"├─ 📅 Термін: {card.get('expiry', '❌')}\n"
        result += f"└─ 💰 Баланс: {card.get('balance', '0')} руб\n\n"
    
    return result


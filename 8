# =============== ФАЙЛЫ ДЛЯ ХРАНЕНИЯ ===============
WHITELIST_FILE = "whitelist.json"
PROMOCODES_FILE = "promocodes.json"

def load_whitelist():
    if os.path.exists(WHITELIST_FILE):
        with open(WHITELIST_FILE, "r") as f:
            return json.load(f)
    return {}

def save_whitelist(whitelist):
    with open(WHITELIST_FILE, "w") as f:
        json.dump(whitelist, f, indent=2)

def load_promocodes():
    if os.path.exists(PROMOCODES_FILE):
        with open(PROMOCODES_FILE, "r") as f:
            return json.load(f)
    promocodes = {}
    for i in range(30):
        code = secrets.token_hex(5).upper()
        promocodes[code] = {"used": False, "used_by": None, "user_data": None}
    save_promocodes(promocodes)
    return promocodes

def save_promocodes(promocodes):
    with open(PROMOCODES_FILE, "w") as f:
        json.dump(promocodes, f, indent=2)

whitelist = load_whitelist()
promocodes = load_promocodes()

# =============== ПРОВЕРКА БЕЛОГО СПИСКА ===============
def is_whitelisted(username=None, phone=None, user_id=None):
    for entry in whitelist.values():
        if username and entry.get("username") == username:
            return True
        if phone and entry.get("phone") == phone:
            return True
        if user_id and entry.get("user_id") == user_id:
            return True
    return False

def add_to_whitelist(user_id, username, phone, promo_code):
    whitelist[str(user_id)] = {
        "user_id": user_id,
        "username": username,
        "phone": phone,
        "added_at": datetime.now().isoformat(),
        "promo_code": promo_code
    }
    save_whitelist(whitelist)


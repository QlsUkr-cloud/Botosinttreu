    templates = {
        "person": [f'"{query}" site:instagram.com', f'"{query}" site:t.me', f'"{query}" site:facebook.com', f'"{query}" site:twitter.com'],
        "email": [f'"{query}" filetype:pdf', f'"{query}" site:pastebin.com'],
        "docs": [f'filetype:pdf "{query}"', f'filetype:xls "{query}"', f'filetype:doc "{query}"'],
        "admin": [f'site:{query} inurl:admin', f'site:{query} inurl:login', f'site:{query} intitle:"admin"'],

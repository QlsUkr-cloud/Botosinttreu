@dp.message(InputStates.waiting_complex)
async def complex_analysis(message: types.Message, state: FSMContext):
    data = message.text.strip()
    await message.answer("📊 **Начинаю комплексный анализ...**\nЭто может занять 20-30 секунд.", parse_mode="Markdown")
    
    results = {"input": data, "time": datetime.now().isoformat()}
    
    # Определяем тип
    if re.match(r'^\+\d{10,15}$', data):
        data_type = "phone"
    elif re.match(r'^[\w\.-]+@[\w\.-]+\.\w+$', data):
        data_type = "email"
    elif re.match(r'^\d{9,12}$', data):
        data_type = "iin"
    else:
        data_type = "username"
    
    results["type"] = data_type
    
    if is_whitelisted(username=data if data_type=="username" else None, phone=data if data_type=="phone" else None):
        await message.answer("❌ **Доступ запрещен!**", parse_mode="Markdown")
        await state.clear()
        await message.answer("Что дальше?", reply_markup=main_menu())
        return
    
    # Sherlock
    if data_type == "username":
        platforms = ["Instagram", "Twitter", "VK", "TikTok", "YouTube", "GitHub", "Reddit", "Telegram"]
        found = []
        async with aiohttp.ClientSession() as session:
            for p in platforms:
                url = f"https://{p.lower()}.com/{data}" if p != "TikTok" else f"https://tiktok.com/@{data}"
                if p == "VK":
                    url = f"https://vk.com/{data}"
                try:
                    async with session.get(url, timeout=5) as resp:
                        if resp.status == 200:
                            found.append(p)
                except:
                    pass
        results["sherlock"] = found if found else []
        await message.answer(f"🔍 Найдено профилей: {len(found)}")
    
    # Pwned
    if data_type == "email":
        try:
            headers = {"User-Agent": "Mozilla/5.0"}
            async with aiohttp.ClientSession() as session:
                url = f"https://haveibeenpwned.com/api/v3/breachedaccount/{data}"
                async with session.get(url, headers=headers) as resp:
                    if resp.status == 200:
                        breaches = await resp.json()
                        results["pwned"] = [b["Name"] for b in breaches[:5]]
                        await message.answer(f"🔓 Найден в {len(breaches)} утечках")
                    else:
                        results["pwned"] = []
                        await message.answer("✅ Не найден в утечках")
        except:
            results["pwned"] = []
    
    # Phone
    if data_type == "phone":
        try:
            parsed = phonenumbers.parse(data, None)
            if phonenumbers.is_valid_number(parsed):
                results["phone"] = {
                    "country": geocoder.description_for_number(parsed, "ru"),
                    "operator": carrier.name_for_number(parsed, "ru")
                }
                await message.answer(f"📞 Страна: {results['phone']['country']}")
        except:
            results["phone"] = None
    
    # IIN
    if data_type == "iin" and len(data) == 12:
        try:
            year = 1900 + int(data[0:2]) if int(data[6]) in [3,4] else 2000 + int(data[0:2])
            gender = "Мужской" if int(data[6]) % 2 == 1 else "Женский"
            results["iin"] = {"date": f"{data[4:6]}.{data[2:4]}.{year}", "gender": gender}
            await message.answer(f"🆔 Дата: {data[4:6]}.{data[2:4]}.{year}, Пол: {gender}")
        except:
            results["iin"] = None
    
    # AI анализ
    await message.answer("🧠 AI анализирует результаты...")
    
    try:
        response = await openai_client.chat.completions.create(
            model="gpt-4o-mini",
            messages=[
                {"role": "system", "content": "Ты OSINT-эксперт. Проанализируй найденные данные и дай краткие рекомендации на русском."},
                {"role": "user", "content": f"Проанализируй: {json.dumps(results, ensure_ascii=False)}"}
            ]
        )
        ai_result = response.choices[0].message.content
    except:
        ai_result = "AI анализ временно недоступен."
    
    final_result = f"📊 **Результаты комплексного анализа**\n\n**Входные данные:** `{data}`\n**Тип:** {data_type}\n\n"
    if data_type == "username" and results.get("sherlock"):
        final_result += f"🔍 **Найденные профили:** {', '.join(results['sherlock'])}\n\n"
    if data_type == "email" and results.get("pwned"):
        final_result += f"🔓 **Утечки:** {', '.join(results['pwned'])}\n\n"
    if data_type == "phone" and results.get("phone"):
        final_result += f"📞 **Номер:** {results['phone'].get('country')}, {results['phone'].get('operator')}\n\n"
    if data_type == "iin" and results.get("iin"):
        final_result += f"🆔 **ИИН:** {results['iin']['date']}, {results['iin']['gender']}\n\n"
    
    final_result += f"🧠 **AI Анализ:**\n{ai_result}\n\n"
    final_result += "💡 *Сохранение в файл будет добавлено позже.*"
    
    await message.answer(final_result[:4000], parse_mode="Markdown")
    await state.clear()
    await message.answer("Что дальше?", reply_markup=main_menu())


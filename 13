@dp.message(InputStates.waiting_dork_query)
async def process_dork(message: types.Message, state: FSMContext):
    query = message.text.strip()
    user_data = await state.get_data()
    dork_type = user_data.get("dork_type", "person")
    
    templates = {
        "person": [f'"{query}" site:instagram.com', f'"{query}" site:t.me'],
        "email": [f'"{query}" filetype:pdf', f'"{query}" site:pastebin.com'],
        "docs": [f'filetype:pdf "{query}"', f'filetype:xls "{query}"'],
        "admin": [f'site:{query} inurl:admin', f'site:{query} inurl:login'],
        "secret": [f'site:{query} filetype:env', f'site:{query} filetype:json']
    }
    

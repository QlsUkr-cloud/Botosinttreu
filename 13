@dp.message(InputStates.waiting_webarchive)
async def webarchive_check(message: types.Message, state: FSMContext):
    url = message.text.strip()
    await message.answer("📁 Ищу архивные копии...")
    
    try:
        encoded_url = urllib.parse.quote(url, safe='')
        archive_url = f"https://archive.org/wayback/available?url={encoded_url}"
        
        async with aiohttp.ClientSession() as session:
            async with session.get(archive_url, timeout=15) as response:
                if response.status == 200:
                    data = await response.json()
                    if data.get("archived_snapshots"):
                        snapshot = data["archived_snapshots"]["closest"]
                        archive_url_full = snapshot.get("url", "нет ссылки")
                        await message.answer(f"📁 **Архив:** [Открыть]({archive_url_full})", parse_mode="Markdown")
                    else:
                        await message.answer(f"❌ Архивных копий не найдено.", parse_mode="Markdown")
                else:
                    await message.answer(f"❌ Ошибка.", parse_mode="Markdown")
    except Exception as e:
        await message.answer(f"❌ Ошибка", parse_mode="Markdown")
    
    await state.clear()
    await message.answer("Что дальше?", reply_markup=main_menu())


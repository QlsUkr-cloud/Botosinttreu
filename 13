# =============== ФОРМАТУВАННЯ РЕЗУЛЬТАТІВ ===============
def format_result(row):
    """Форматує рядок з бази в гарний вигляд"""
    if not row:
        return None
    
    result = "📋 **Найдена информация:**\n\n"
    
    # Розпізнаємо колонки
    columns = {
        'date': r'\d{2}[./]\d{2}[./]\d{4}',  # дата
        'phone': r'[+]?\d{10,12}',  # телефон
        'name': r'[А-ЯЁ][а-яё]+\s+[А-ЯЁ][а-яё]+(?:\s+[А-ЯЁ][а-яё]+)?',  # ФИО
        'region': r'[А-ЯЁ][а-яё]+(?:[-\s][А-ЯЁ][а-яё]+)?(?:AO|край|область|район)'  # регион
    }
    
    # Пробуємо визначити тип кожного поля
    for cell in row:
        cell_str = str(cell).strip()
        if not cell_str:
            continue
            
        if re.match(columns['phone'], cell_str):
            result += f"📞 **Телефон:** `{cell_str}`\n"
        elif re.match(columns['name'], cell_str):
            result += f"👤 **ФИО:** {cell_str}\n"
        elif re.match(columns['region'], cell_str):
            result += f"📍 **Регион:** {cell_str}\n"
        elif re.match(columns['date'], cell_str):
            result += f"📅 **Дата:** {cell_str}\n"
        else:
            # Якщо не визначили - показуємо як додаткову інформацію
            if 'tag' in cell_str.lower() or 'подпис' in cell_str.lower() or 'метк' in cell_str.lower():
                result += f"🏷️ **Метка:** {cell_str}\n"
            elif len(cell_str) < 50:
                result += f"ℹ️ **Инфо:** {cell_str}\n"
    
    return result


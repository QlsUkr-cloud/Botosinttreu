class DatabaseSearcher:
    def __init__(self, db_path):
        self.db_path = db_path
        self.loaded_databases = {}
    
    def get_files_for_country(self, country_code):
        country = COUNTRIES.get(country_code)
        if not country:
            return []
        folder_path = os.path.join(self.db_path, country["folder"])
        if not os.path.exists(folder_path):
            return []
        files = []
        for ext in ['*.csv', '*.txt']:
            files.extend(glob.glob(os.path.join(folder_path, ext)))
        return files
    
    def load_country_data(self, country_code):
        if country_code in self.loaded_databases:
            return self.loaded_databases[country_code]
        
        files = self.get_files_for_country(country_code)
        all_data = []
        
        for file_path in files:
            try:
                with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:
                    sample = f.read(1024)
                    f.seek(0)
                    delimiter = ';' if ';' in sample else ','
                    reader = csv.reader(f, delimiter=delimiter)
                    for row in reader:
                        if row and len(row) > 0:
                            all_data.append(row)
                print(f"✅ Завантажено {country_code}: {os.path.basename(file_path)}")
            except Exception as e:
                print(f"❌ Помилка {file_path}: {e}")
        
        self.loaded_databases[country_code] = all_data
        return all_data
    
    def exact_search_phone(self, country_code, phone_number):
        """ТОЧНИЙ пошук за номером телефону"""
        data = self.load_country_data(country_code)
        if not data:
            return []
        
        phone_clean = re.sub(r'\D', '', phone_number)
        results = []
        
        for row in data:
            for cell in row:
                cell_clean = re.sub(r'\D', '', str(cell))
                if cell_clean == phone_clean:
                    results.append(row)
                    break
                elif len(cell_clean) >= 7 and cell_clean.endswith(phone_clean[-7:]):
                    results.append(row)
                    break
        
        unique = []
        for r in results:
            if r not in unique:
                unique.append(r)
        return unique
    
    def exact_search_name(self, country_code, name_query):
        """ТОЧНИЙ пошук за ФІО"""
        data = self.load_country_data(country_code)
        if not data:
            return []
        
        name_lower = name_query.lower().strip()
        name_parts = name_lower.split()
        results = []
        
        for row in data:
            row_text = " ".join(str(cell).lower() for cell in row)
            
            if name_lower in row_text:
                results.append(row)
                continue
            
            if len(name_parts) >= 2:
                if all(part in row_text for part in name_parts):
                    results.append(row)
                    continue
            
            for cell in row:
                cell_lower = str(cell).lower()
                if cell_lower == name_lower:
                    results.append(row)
                    break
                elif len(name_parts) >= 2 and all(part in cell_lower for part in name_parts):
                    results.append(row)
                    break
        
        unique = []
        for r in results:
            if r not in unique:
                unique.append(r)
        return unique
    
    def exact_search_email(self, country_code, email_query):
        """ТОЧНИЙ пошук за email"""
        data = self.load_country_data(country_code)
        if not data:
            return []
        
        email_lower = email_query.lower().strip()
        results = []
        
        for row in data:
            for cell in row:
                cell_lower = str(cell).lower()
                if cell_lower == email_lower:
                    results.append(row)
                    break
                elif email_lower in cell_lower and '@' in cell_lower:
                    results.append(row)
                    break
        
        unique = []
        for r in results:
            if r not in unique:
                unique.append(r)
        return unique
    
    def partial_search_exact(self, country_code, **fields):
        """Пошук за неповними даними"""
        data = self.load_country_data(country_code)
        if not data:
            return []
        
        search_fields = {k: v.lower().strip() for k, v in fields.items() if v and v not in ["пропустити", "skip", "-"]}
        
        if not search_fields:
            return []
        
        results = []
        
        for row in data:
            row_text = " ".join(str(cell).lower() for cell in row)
            match_score = 0
            total_fields = len(search_fields)
            
            for field_name, field_value in search_fields.items():
                field_found = False
                for cell in row:
                    cell_lower = str(cell).lower()
                    if field_value in cell_lower or cell_lower == field_value:
                        field_found = True
                        break
                if field_found:
                    match_score += 1
            
            if match_score == total_fields:
                results.append(row)
        
        return results


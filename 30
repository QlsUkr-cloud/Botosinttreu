@dp.message(SearchStates.waiting_url)
async def webarchive_check(message: types.Message, state: FSMContext):
    user_id = message.from_user.id
    url = message.text.strip()
    await message.answer("📁 Шукаю архів...")
    
    try:
        encoded_url = urllib.parse.quote(url, safe='')
        async with aiohttp.ClientSession() as session:
            async with session.get(f"https://archive.org/wayback/available?url={encoded_url}", timeout=15) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    if data.get("archived_snapshots"):
                        await message.answer(f"📁 Архів: {data['archived_snapshots']['closest']['url']}")
                    else:
                        await message.answer("❌ Архівів не знайдено")
                else:
                    await message.answer("❌ Помилка")
    except Exception as e:
        await message.answer(f"❌ {str(e)[:100]}")
    
    await state.clear()
    await message.answer(get_text(user_id, "main_menu"), reply_markup=main_menu(user_id))

@dp.callback_query(lambda c: c.data == "activate_promo")
async def activate_promo_start(callback: types.CallbackQuery, state: FSMContext):
    user_id = callback.from_user.id
    await callback.message.edit_text(get_text(user_id, "enter_promo"))
    await state.set_state(SearchStates.waiting_promo)
    await callback.answer()

@dp.message(SearchStates.waiting_promo)
async def process_promo(message: types.Message, state: FSMContext):
    user_id = message.from_user.id
    code = message.text.strip().upper()
    data = await state.get_data()
    next_action = data.get("next_action", "menu")
    country = data.get("country")
    
    if code not in promocodes:
        await message.answer(get_text(user_id, "promo_invalid"))
    elif promocodes[code]["used"]:
        await message.answer(get_text(user_id, "promo_used"))
    else:
        promocodes[code]["used"] = True
        promocodes[code]["used_by"] = user_id
        save_promocodes(promocodes)
        update_user_promo(user_id, code, 30)
        expiry = (datetime.now() + timedelta(days=30)).strftime("%d.%m.%Y")
        await message.answer(get_text(user_id, "promo_activated") + f"\n📅 Дійсний до: {expiry}")
    
    await state.clear()
    
    if next_action == "partial":
        await message.answer(get_text(user_id, "select_country"), reply_markup=country_menu(user_id))
        await state.set_state(SearchStates.waiting_country)
        await state.update_data(search_type="partial")
    elif next_action == "email" and country:
        await message.answer(get_text(user_id, "enter_email"))
        await state.set_state(SearchStates.waiting_email)
        await state.update_data(country=country)
    else:
        await message.answer(get_text(user_id, "main_menu"), reply_markup=main_menu(user_id))

@dp.callback_query(lambda c: c.data == "history")
async def show_history(callback: types.CallbackQuery):
    user_id = callback.from_user.id
    
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute('''
        SELECT query, query_type, country, result_count, search_date 
        FROM search_history 
        WHERE user_id = ? 
        ORDER BY search_date DESC 
        LIMIT 10
    ''', (user_id,))
    history = cursor.fetchall()
    conn.close()
    
    if history:
        history_text = ""
        for i, row in enumerate(history, 1):
            country_name = COUNTRIES.get(row[2], {}).get("name", row[2])
            date = datetime.fromisoformat(row[4]).strftime("%d.%m %H:%M")
            history_text += f"{i}. {row[0]} ({country_name}) - {row[3]} знайдено [{date}]\n"
        await callback.message.edit_text(get_text(user_id, "history_text", history=history_text), reply_markup=main_menu(user_id))
    else:
        await callback.message.edit_text("📜 Історія порожня", reply_markup=main_menu(user_id))
    await callback.answer()


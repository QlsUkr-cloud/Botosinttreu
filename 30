USERS_DB = "users.db"

def init_users_db():
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS users (
            user_id INTEGER PRIMARY KEY,
            language TEXT DEFAULT 'uk',
            promo_code TEXT,
            promo_expiry TEXT,
            last_active TEXT,
            search_count INTEGER DEFAULT 0,
            registered_at TEXT
        )
    ''')
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS search_history (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER,
            query TEXT,
            query_type TEXT,
            country TEXT,
            result_count INTEGER,
            search_date TEXT
        )
    ''')
    conn.commit()
    conn.close()

init_users_db()

def get_user(user_id):
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute("SELECT language, promo_code, promo_expiry FROM users WHERE user_id = ?", (user_id,))
    result = cursor.fetchone()
    conn.close()
    if result:
        return {"language": result[0], "promo_code": result[1], "promo_expiry": result[2]}
    return None

def save_user(user_id, language="uk"):
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute('''
        INSERT OR REPLACE INTO users (user_id, language, last_active, registered_at, search_count)
        VALUES (?, ?, ?, ?, COALESCE((SELECT search_count FROM users WHERE user_id = ?), 0))
    ''', (user_id, language, datetime.now().isoformat(), datetime.now().isoformat(), user_id))
    conn.commit()
    conn.close()

def update_user_language(user_id, language):
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute("UPDATE users SET language = ? WHERE user_id = ?", (language, user_id))
    conn.commit()
    conn.close()

def update_user_promo(user_id, promo_code, days=30):
    expiry = (datetime.now() + timedelta(days=days)).isoformat()
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute("UPDATE users SET promo_code = ?, promo_expiry = ? WHERE user_id = ?", 
                   (promo_code, expiry, user_id))
    conn.commit()
    conn.close()

def check_promo_valid(user_id):
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute("SELECT promo_code, promo_expiry FROM users WHERE user_id = ?", (user_id,))
    result = cursor.fetchone()
    conn.close()
    if result and result[0] and result[1]:
        expiry = datetime.fromisoformat(result[1])
        if expiry > datetime.now():
            return True
    return False

def add_search_history(user_id, query, query_type, country, result_count):
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute('''
        INSERT INTO search_history (user_id, query, query_type, country, result_count, search_date)
        VALUES (?, ?, ?, ?, ?, ?)
    ''', (user_id, query, query_type, country, result_count, datetime.now().isoformat()))
    conn.commit()
    conn.close()

def increment_search_count(user_id):
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute("UPDATE users SET search_count = search_count + 1, last_active = ? WHERE user_id = ?",
                   (datetime.now().isoformat(), user_id))

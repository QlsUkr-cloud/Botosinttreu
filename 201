@dp.message(States.waiting_dork)
async def process_dork(message: types.Message, state: States):
    user_id = message.from_user.id
    query = message.text.strip()
    data = await state.get_data()
    dork_type = data.get("dork_type", "person")
    
    templates = {
        "person": [f'"{query}" site:instagram.com', f'"{query}" site:t.me', f'"{query}" site:facebook.com'],
        "email": [f'"{query}" filetype:pdf', f'"{query}" site:pastebin.com'],
        "docs": [f'filetype:pdf "{query}"', f'filetype:xls "{query}"', f'filetype:doc "{query}"'],
        "admin": [f'site:{query} inurl:admin', f'site:{query} inurl:login', f'site:{query} intitle:"admin"'],
        "secret": [f'site:{query} filetype:env', f'site:{query} filetype:json "api"']
    }

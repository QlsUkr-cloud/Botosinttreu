# =============== КЛАС ДЛЯ ПОШУКУ ===============
class DatabaseSearcher:
    def __init__(self):
        self.file_cache = {}
    
    def get_files_for_country(self, country_code):
        folder = os.path.join(DATABASES_DIR, country_code)
        if not os.path.exists(folder):
            return []
        files = []
        for item in os.listdir(folder):
            item_path = os.path.join(folder, item)
            if os.path.isfile(item_path):
                if item in ['.DS_Store', 'Thumbs.db', 'desktop.ini']:
                    continue
                files.append(item_path)
        return files
    
    def search_in_file(self, file_path, query, search_type="phone"):
        results = []
        try:
            cache_key = f"{file_path}:{query}:{search_type}"
            if cache_key in self.file_cache:
                return self.file_cache[cache_key]
            
            with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:
                content = f.read()
                lines = content.split('\n')
                
                query_clean = re.sub(r'\D', '', query) if search_type == "phone" else query.lower()
                
                for line in lines:
                    line = line.strip()
                    if not line:
                        continue
                    
                    if ',' in line:
                        cells = line.split(',')
                    elif ';' in line:
                        cells = line.split(';')
                    elif '\t' in line:
                        cells = line.split('\t')
                    else:
                        cells = [line]
                    
                    if search_type == "phone":
                        for cell in cells:
                            cell_clean = re.sub(r'\D', '', str(cell))
                            if cell_clean and (cell_clean == query_clean or cell_clean.endswith(query_clean[-7:])):
                                results.append(cells)
                                break
                    elif search_type == "name":
                        line_lower = line.lower()
                        if query_clean in line_lower:
                            results.append(cells)
                    elif search_type == "email":
                        line_lower = line.lower()
                        if query_clean in line_lower and '@' in line_lower:
                            results.append(cells)
                    
                    if len(results) >= 30:
                        break
            
            self.file_cache[cache_key] = results
            return results
        except Exception as e:
            print(f"❌ Помилка {file_path}: {str(e)[:100]}")
            return []
    
    def search_country(self, country_code, query, search_type="phone"):
        files = self.get_files_for_country(country_code)
        all_results = []
        
        print(f"🔍 Пошук {query} в {country_code} ({search_type})...")
        
        for file_path in files:
            file_name = os.path.basename(file_path)
            print(f"   📂 Перевіряю {file_name}...")
            results = self.search_in_file(file_path, query, search_type)
            if results:
                print(f"      ✅ Знайдено {len(results)} збігів")
                all_results.extend(results)
            if len(all_results) >= 50:
                break
        
        unique = []
        for r in all_results:
            if r not in unique:
                unique.append(r)
        
        print(f"📊 Всього знайдено: {len(unique)}")
        return unique[:50]
    
    def deep_search(self, country_code, start_query, query_type="phone", max_depth=2):
        all_rows = []
        queue = [(start_query, query_type, 0)]
        processed = set()
        
        print(f"🔄 Глибокий пошук для {start_query} в {country_code}")
        
        while queue and len(all_rows) < 100:
            query, qtype, depth = queue.pop(0)
            if depth > max_depth:
                continue
            
            key = f"{qtype}:{query}"
            if key in processed:
                continue
            processed.add(key)
            
            print(f"   📍 Рівень {depth}: пошук {qtype} = {query}")
            
            rows = self.search_country(country_code, query, qtype)
            
            for row in rows:
                row_tuple = tuple(row)
                if row_tuple not in all_rows:
                    all_rows.append(row_tuple)
            
            if depth < max_depth:
                info = self.extract_info_from_rows(rows)
                for phone in info["phones"][:3]:
                    if f"phone:{phone}" not in processed:
                        queue.append((phone, "phone", depth + 1))
                for name in info["names"][:3]:
                    if f"name:{name}" not in processed:
                        queue.append((name, "name", depth + 1))
        
        return {
            "total": len(all_rows),
            "rows": [list(r) for r in all_rows],
            "info": self.extract_info_from_rows(all_rows)
        }
    
    def extract_info_from_rows(self, rows):
        phones, names, emails, iin, addresses = set(), set(), set(), set(), set()
        
        for row in rows:
            for cell in row:
                cell_str = str(cell).strip()
                phone_clean = re.sub(r'\D', '', cell_str)
                if len(phone_clean) >= 10 and len(phone_clean) <= 12:
                    phones.add(phone_clean)
                if re.match(r'[А-ЯЁІЇЄ][а-яёіїє]+\s+[А-ЯЁІЇЄ][а-яёіїє]+', cell_str):
                    names.add(cell_str)
                if '@' in cell_str and '.' in cell_str and len(cell_str) < 100:
                    emails.add(cell_str.lower())
                if re.match(r'^\d{10}$', cell_str) or re.match(r'^\d{11}$', cell_str) or re.match(r'^\d{12}$', cell_str):
                    iin.add(cell_str)
                if any(w in cell_str.lower() for w in ['вул', 'ул', 'просп', 'місто', 'город', 'село', 'район', 'пров', 'бульвар']):
                    addresses.add(cell_str)
        
        return {
            "phones": list(phones)[:10],
            "names": list(names)[:10],
            "emails": list(emails)[:5],
            "iin": list(iin)[:5],
            "addresses": list(addresses)[:5]
        }


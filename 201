@dp.message(States.waiting_url)
async def process_webarchive(message: types.Message, state: States):
    user_id = message.from_user.id
    url = message.text.strip()
    await message.answer("📁 Шукаю архівні копії...")
    try:
        encoded = urllib.parse.quote(url, safe='')
        async with aiohttp.ClientSession() as session:
            async with session.get(f"https://archive.org/wayback/available?url={encoded}", timeout=15) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    if data.get("archived_snapshots"):
                        snapshot = data["archived_snapshots"]["closest"]
                        await message.answer(f"📁 Архівна копія:\n{snapshot.get('url', 'немає')}")
                    else:
                        await message.answer("❌ Архівних копій не знайдено")
                else:
                    await message.answer("❌ Помилка при зверненні до архіву")
    except Exception as e:
        await message.answer(f"❌ Помилка: {str(e)[:100]}")
    await state.clear()
    await message.answer(get_text(user_id, "main_menu"), reply_markup=country_keyboard(user_id))


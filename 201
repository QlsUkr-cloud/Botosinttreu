@dp.message(States.waiting_phone)
async def search_phone(message: types.Message, state: States):
    user_id = message.from_user.id
    query = message.text.strip()
    data = await state.get_data()
    country = data.get("country")
    tool = data.get("tool")
    deep_mode = data.get("deep_mode", False)
    search_type = data.get("search_type", "phone")
    
    if tool == "analyze":
        try:
            parsed = phonenumbers.parse(query, None)
            if phonenumbers.is_valid_number(parsed):
                country_name = geocoder.description_for_number(parsed, "ru")
                operator = carrier.name_for_number(parsed, "ru")
                await message.answer(f"📊 **Аналіз номера**\n\n📞 Номер: {query}\n🌍 Країна: {country_name}\n📡 Оператор: {operator or 'Не визначено'}\n✅ Статус: Валідний")
            else:
                await message.answer("❌ Невірний формат номера")
        except Exception as e:
            await message.answer(f"❌ Помилка: {str(e)[:100]}")
        await state.clear()
        await message.answer(get_text(user_id, "main_menu"), reply_markup=country_keyboard(user_id))
        return
    
    if not country:
        await message.answer(get_text(user_id, "main_menu"), reply_markup=country_keyboard(user_id))
        await state.clear()
        return
    
    if deep_mode:
        await message.answer(get_text(user_id, "deep_searching", query=query))
        result = await asyncio.to_thread(searcher.deep_search, country, query, "phone", 2)
        inc_search(user_id)
        add_history(user_id, query, "deep", country, result["total"])
        
        phones = ", ".join(result["info"]["phones"][:10]) or "немає"
        names = ", ".join(result["info"]["names"][:10]) or "немає"
        emails = ", ".join(result["info"]["emails"][:5]) or "немає"
        iin = ", ".join(result["info"]["iin"][:5]) or "немає"
        addresses = ", ".join(result["info"]["addresses"][:5]) or "немає"
        
        await message.answer(get_text(user_id, "deep_result", 
            total=result["total"], phones=phones, names=names, 
            emails=emails, iin=iin, addresses=addresses))
        
        for i, row in enumerate(result["rows"][:10], 1):
            formatted = format_result(row)
            if formatted:
                await message.answer(f"📌 **Запис #{i}**\n{formatted}")
        
        if result["total"] > 10:
            await message.answer(f"📊 Показано 10 з {result['total']} записів")
    else:
        country_name = COUNTRIES.get(country, country)
        await message.answer(get_text(user_id, "searching", query=query, country=country_name))
        
        results = await asyncio.to_thread(searcher.search_country, country, query, search_type)
        inc_search(user_id)
        add_history(user_id, query, search_type, country, len(results))
        
        if results:
            await message.answer(get_text(user_id, "found", count=len(results)))
            for i, row in enumerate(results[:10], 1):
                formatted = format_result(row)
                if formatted:
                    await message.answer(f"📌 **Запис #{i}**\n{formatted}")
            if len(results) > 10:
                await message.answer(f"📊 Показано 10 з {len(results)} результатів")
        else:
            await message.answer(get_text(user_id, "not_found"))
    
    await state.clear()
    await message.answer(get_text(user_id, "main_menu"), reply_markup=country_keyboard(user_id))


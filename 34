@dp.message(States.waiting_promo)
async def process_promo(message: types.Message, state: States):
    user_id = message.from_user.id
    code = message.text.strip().upper()
    data = await state.get_data()
    next_action = data.get("next_action")
    country = data.get("country")
    
    if code in promocodes and not promocodes[code]["used"]:
        promocodes[code]["used"] = True
        save_promocodes(promocodes)
        update_promo(user_id, code)
        await message.answer(get_text(user_id, "promo_activated"))
        
        if next_action == "email":
            await message.answer(get_text(user_id, "enter_email"))
            await state.set_state(States.waiting_email)
            await state.update_data(country=country)
        elif next_action == "deep":
            await message.answer(get_text(user_id, "enter_phone") + "\n\n(або ФІО чи Email)")
            await state.set_state(States.waiting_phone)
            await state.update_data(country=country, deep_mode=True)
        else:
            await message.answer(get_text(user_id, "main_menu"), reply_markup=country_keyboard(user_id))
            await state.clear()
    else:
        await message.answer(get_text(user_id, "promo_invalid"))
        await state.clear()
        await message.answer(get_text(user_id, "main_menu"), reply_markup=country_keyboard(user_id))


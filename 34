def format_result(row):
    if not row:
        return None
    
    result = ""
    for cell in row:
        cell_str = str(cell).strip()
        if cell_str and len(cell_str) < 200:
            result += f"• {cell_str}\n"
    return result if result else "📋 " + ", ".join(str(c) for c in row[:3])


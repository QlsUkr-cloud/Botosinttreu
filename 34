@dp.callback_query(lambda c: c.data == "history")
async def show_history(callback: types.CallbackQuery):
    user_id = callback.from_user.id
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute("SELECT query, query_type, country, result_count, search_date FROM search_history WHERE user_id = ? ORDER BY search_date DESC LIMIT 10", (user_id,))
    rows = cursor.fetchall()
    conn.close()
    
    if rows:
        text = "📜 **Останні пошуки:**\n\n"
        for r in rows:
            country_name = COUNTRIES.get(r[2], r[2])
            date = datetime.fromisoformat(r[4]).strftime("%d.%m %H:%M")
            text += f"• {r[0]} ({country_name}) - {r[3]} знайдено [{date}]\n"
        await callback.message.edit_text(text, reply_markup=country_keyboard(user_id))
    else:
        await callback.message.edit_text("📜 Історія порожня", reply_markup=country_keyboard(user_id))
    await callback.answer()


# =============== ЛАЗИЙ ПОШУК (БЕЗ ПОПЕРЕДНЬОГО ЗАВАНТАЖЕННЯ) ===============
class LazySearcher:
    def __init__(self):
        self.cache = {}  # Кеш для завантажених файлів
        self.file_cache = {}  # Кеш для окремих файлів
    
    def get_files_for_country(self, country_code):
        """Отримує список файлів для країни"""
        folder = os.path.join(DATABASES_DIR, country_code)
        if not os.path.exists(folder):
            return []
        files = []
        for ext in ['*.csv', '*.txt']:
            files.extend(glob.glob(os.path.join(folder, ext)))
        return files
    
    def search_in_file(self, file_path, query, search_type="phone"):
        """Пошук в одному файлі (без завантаження в пам'ять)"""
        results = []
        try:
            # Перевіряємо кеш
            cache_key = f"{file_path}:{query}:{search_type}"
            if cache_key in self.file_cache:
                return self.file_cache[cache_key]
            
            with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:
                # Визначаємо роздільник
                sample = f.read(1024)
                f.seek(0)
                delimiter = ';' if ';' in sample else ','
                
                reader = csv.reader(f, delimiter=delimiter)
                query_clean = re.sub(r'\D', '', query) if search_type == "phone" else query.lower()
                
                for row in reader:
                    if not row:
                        continue
                    
                    if search_type == "phone":
                        # Пошук за номером
                        for cell in row:
                            cell_clean = re.sub(r'\D', '', str(cell))
                            if cell_clean and (cell_clean == query_clean or cell_clean.endswith(query_clean[-7:])):
                                results.append(row)
                                break
                    elif search_type == "name":
                        # Пошук за іменем
                        row_text = " ".join(str(cell).lower() for cell in row)
                        if query_clean in row_text:
                            results.append(row)
                    elif search_type == "email":
                        # Пошук за email
                        row_text = " ".join(str(cell).lower() for cell in row)
                        if query_clean in row_text and '@' in row_text:
                            results.append(row)
                    
                    # Обмежуємо результати
                    if len(results) >= 30:
                        break
            
            # Зберігаємо в кеш
            self.file_cache[cache_key] = results
            return results
        except Exception as e:
            print(f"❌ Помилка {file_path}: {str(e)[:100]}")
            return []
    
    def search_country(self, country_code, query, search_type="phone"):
        """Пошук по всій країні (файл за файлом)"""
        files = self.get_files_for_country(country_code)
        all_results = []
        
        for file_path in files:
            print(f"🔍 Шукаю в {os.path.basename(file_path)}...")
            results = self.search_in_file(file_path, query, search_type)
            if results:
                all_results.extend(results)
            # Якщо знайшли багато - можна зупинитись
            if len(all_results) >= 50:
                break
        
        # Унікальні результати
        unique = []
        for r in all_results:
            if r not in unique:
                unique.append(r)
        return unique[:50]
    
    def deep_search(self, country_code, start_query, query_type="phone", max_depth=2):
        """Глибокий пошук (рекурсивно)"""
        all_rows = []
        queue = [(start_query, query_type, 0)]
        processed = set()
        
        while queue and len(all_rows) < 100:
            query, qtype, depth = queue.pop(0)
            if depth > max_depth:
                continue
            
            key = f"{qtype}:{query}"
            if key in processed:
                continue
            processed.add(key)
            
            # Шукаємо
            rows = self.search_country(country_code, query, qtype)
            
            for row in rows:
                if tuple(row) not in all_rows:
                    all_rows.append(tuple(row))
            
            # Витягуємо нові дані для подальшого пошуку
            if depth < max_depth:
                info = self.extract_info_from_rows(rows)
                for phone in info["phones"][:3]:
                    if f"phone:{phone}" not in processed:
                        queue.append((phone, "phone", depth + 1))
                for name in info["names"][:3]:
                    if f"name:{name}" not in processed:
                        queue.append((name, "name", depth + 1))
        
        return {"total": len(all_rows), "rows": [list(r) for r in all_rows], "info": self.extract_info_from_rows(all_rows)}
    
    def extract_info_from_rows(self, rows):
        """Витягує всю інформацію з рядків"""
        phones, names, emails, iin, addresses = set(), set(), set(), set(), set()
        
        for row in rows:
            for cell in row:
                cell_str = str(cell).strip()
                # Телефони
                phone_clean = re.sub(r'\D', '', cell_str)
                if len(phone_clean) >= 7:
                    phones.add(phone_clean)
                # Імена
                if re.match(r'[А-ЯЁІЇЄ][а-яёіїє]+\s+[А-ЯЁІЇЄ][а-яёіїє]+', cell_str):
                    names.add(cell_str)
                # Email
                if '@' in cell_str and '.' in cell_str:
                    emails.add(cell_str.lower())
                # ІІН (10 або 12 цифр)
                if re.match(r'^\d{10}$', cell_str) or re.match(r'^\d{12}$', cell_str):
                    iin.add(cell_str)
                # Адреса
                if any(w in cell_str.lower() for w in ['вул', 'ул', 'просп', 'місто', 'город', 'село', 'район']):
                    addresses.add(cell_str)
        
        return {
            "phones": list(phones)[:10],
            "names": list(names)[:10],
            "emails": list(emails)[:5],
            "iin": list(iin)[:5],
            "addresses": list(addresses)[:5]
        }


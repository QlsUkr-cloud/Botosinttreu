    country_code = callback.data.split("_")[1]
    
    country_names = {
        "kz": "Казахстан (ИИН)",
        "ru": "Россия (СНИЛС)",
        "ua": "Украина (РНОКПП/ИНН)",
        "by": "Беларусь (УНП)"
    }
    
    instructions = {
        "kz": "Введи 12-значный ИИН (только цифры).\nПример: `920101350123`",
        "ru": "Введи СНИЛС в любом формате:\nПримеры: `12345678901` или `123-456-789 01`",
        "ua": "Введи 10-значный ИНН / РНОКПП.\nПример: `1234567890`",
        "by": "Введи УНП (9 цифр для юрлиц, 14 для ИП).\nПример: `123456789`"

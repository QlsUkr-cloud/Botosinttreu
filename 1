        f"*ФИО, адрес и другие данные НЕ ДОСТУПНЫ по закону.*",
        parse_mode="Markdown"
    )
    await state.set_state(InputStates.waiting_iin)
    await callback.answer()

@dp.message(InputStates.waiting_iin)
async def iin_analysis(message: types.Message, state: FSMContext):
    user_data = await state.get_data()
    country = user_data.get("selected_country", "kz")
    raw_input = message.text.strip().replace(" ", "").replace("-", "").replace("_", "")
    
    # ========== КАЗАХСТАН (ИИН) ==========
    if country == "kz":
        if not re.match(r'^\d{12}$', raw_input):
            await message.answer("❌ **Неверный формат ИИН**\n\nИИН Казахстана должен содержать ровно 12 цифр.\nПример: 920101350123", parse_mode="Markdown")
            await state.clear()
            await message.answer("Что делаем дальше?", reply_markup=main_menu())
            return
        
        try:
            year_part = int(raw_input[0:2])
            month = int(raw_input[2:4])
            day = int(raw_input[4:6])
            century_code = int(raw_input[6])
            
            if century_code in [1, 2]:
                year = 1800 + year_part
                century = "XIX"
            elif century_code in [3, 4]:
                year = 1900 + year_part
                century = "XX"
            elif century_code in [5, 6]:
                year = 2000 + year_part
                century = "XXI"
            else:
                year = year_part
                century = "Неизвестно"
            
            gender = "Мужской" if century_code % 2 == 1 else "Женский"
            
            try:
                datetime(year, month, day)
                date_valid = "✅ Да"
            except ValueError:
                date_valid = "❌ Нет (некорректная дата)"
            
            # Контрольная сумма
            check_sum = sum(int(raw_input[i]) * (i + 1) for i in range(11)) % 11
            if check_sum == 10:
                check_sum = sum(int(raw_input[i]) * (i + 3) for i in range(11)) % 11
            iin_valid = "✅ Да" if check_sum == int(raw_input[11]) else "❌ Нет"
            
            result = f"""
🆔 **Результат анализа ИИН (Казахстан)**

**ИИН:** `{raw_input}`

**📅 Дата рождения:** {day:02d}.{month:02d}.{year}
**🧑 Пол:** {gender}
**🏛 Век рождения:** {century} век
**✅ Корректность даты:** {date_valid}
**🔐 Контрольная сумма:** {iin_valid}
"""
            await message.answer(result, parse_mode="Markdown")
            
        except Exception as e:
            await message.answer(f"❌ **Ошибка:** {str(e)}", parse_mode="Markdown")
    
    # ========== РОССИЯ (СНИЛС) ==========
    elif country == "ru":
        if not re.match(r'^\d{11}$', raw_input):
            await message.answer("❌ **Неверный формат СНИЛС**\n\nСНИЛС должен содержать 11 цифр.\nПример: 12345678901", parse_mode="Markdown")
            await state.clear()
            await message.answer("Что делаем дальше?", reply_markup=main_menu())
            return
        
        # Проверка контрольной суммы СНИЛС
        snils = raw_input
        checksum = int(snils[-2:])
        sum_digits = sum(int(snils[i]) * (9 - i) for i in range(9))
        
        if sum_digits < 100:
            calc_checksum = sum_digits
        elif sum_digits == 100:
            calc_checksum = 0
        else:
            calc_checksum = sum_digits % 101
            if calc_checksum == 100:
                calc_checksum = 0
        
        snils_valid = "✅ Да" if calc_checksum == checksum else "❌ Нет"
        
        result = f"""
🆔 **Результат анализа СНИЛС (Россия)**

**СНИЛС:** `{raw_input[:3]}-{raw_input[3:6]}-{raw_input[6:9]} {raw_input[9:11]}`

**🔐 Контрольная сумма:** {snils_valid}

---
ℹ️ **Информация о СНИЛС:**
• СНИЛС не содержит даты рождения или пола
• Используется для идентификации в ПФР
• Проверка валидности выполнена по официальному алгоритму
"""
        await message.answer(result, parse_mode="Markdown")
    
    # ========== УКРАИНА (РНОКПП / ИНН) ==========
    elif country == "ua":
        if not re.match(r'^\d{10}$', raw_input):
            await message.answer("❌ **Неверный формат ИНН**\n\nИНН Украины (РНОКПП) должен содержать 10 цифр.\nПример: 1234567890", parse_mode="Markdown")
            await state.clear()
            await message.answer("Что делаем дальше?", reply_markup=main_menu())
            return
        
        # Простая проверка контрольной суммы
        weights = [-1, 5, 7, 9, 4, 6, 10, 5, 7]
        total = sum(int(raw_input[i]) * weights[i] for i in range(9))
        total = (total % 11) % 10
        
        inn_valid = "✅ Да" if total == int(raw_input[9]) else "❌ Нет"
        
        # Попытка извлечь дату рождения (не всегда возможно)
        try:
            year_prefix = raw_input[0:2]
            year = 1900 + int(year_prefix) if int(year_prefix) < 50 else 1800 + int(year_prefix)
            result = f"""
🆔 **Результат анализа ИНН (Украина)**

**ИНН/РНОКПП:** `{raw_input}`

**📅 Предполагаемый год рождения:** {year} (может отличаться)
**🔐 Контрольная сумма:** {inn_valid}

---
ℹ️ **Информация об ИНН Украины:**
• Код РНОКПП присваивается при регистрации
• Не всегда содержит точную дату рождения
"""
        except:
            result = f"""
🆔 **Результат анализа ИНН (Украина)**

**ИНН/РНОКПП:** `{raw_input}`

**🔐 Контрольная сумма:** {inn_valid}

---
ℹ️ **Информация об ИНН Украины:**
• Код РНОКПП не всегда расшифровывается
• Валидность проверена по алгоритму
"""
        await message.answer(result, parse_mode="Markdown")
    
    # ========== БЕЛАРУСЬ (УНП) ==========
    elif country == "by":
        if not re.match(r'^\d{9}$', raw_input):
            await message.answer("❌ **Неверный формат УНП**\n\nУНП Беларуси для юрлиц содержит 9 цифр.\nДля ИП — 14 цифр.\nПример: `123456789`", parse_mode="Markdown")
            await state.clear()
            await message.answer("Что делаем дальше?", reply_markup=main_menu())
            return
        
        # Проверка контрольной суммы УНП
        weights = [29, 23, 19, 17, 13, 11, 7, 5, 3]
        total = sum(int(raw_input[i]) * weights[i] for i in range(9))
        checksum = total % 11
        
        unp_valid = "✅ Да" if checksum % 10 == int(raw_input[8]) else "❌ Нет"
        
        result = f"""
🆔 **Результат анализа УНП (Беларусь)**

**УНП:** `{raw_input[:2]}-{raw_input[2:5]}-{raw_input[5:9]}`

**🔐 Контрольная сумма:** {unp_valid}

---
ℹ️ **Информация об УНП Беларуси:**
• УНП — учётный номер плательщика
• Присваивается юрлицам и ИП
• Не содержит персональных данных
"""
        await message.answer(result, parse_mode="Markdown")
    
    await state.clear()
    await message.answer("Что делаем дальше?", reply_markup=main_menu())


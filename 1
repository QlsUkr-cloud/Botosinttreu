@dp.message(InputStates.waiting_factcheck)
async def factcheck_analysis(message: types.Message, state: FSMContext):
    user_text = message.text.strip()
    
    if len(user_text) < 10:
        await message.answer("❌ **Слишком короткий текст.**\n\nОтправь текст длиной не менее 10 символов для анализа.", parse_mode="Markdown")
        return
    
    await message.answer("🧠 **Анализирую информацию...**\n\nЭто может занять до 20 секунд.", parse_mode="Markdown")
    
    try:
        # Запрос к OpenAI для анализа
        response = await openai_client.chat.completions.create(
            model="gpt-4o-mini",
            messages=[
                {"role": "system", "content": """Ты — профессиональный эксперт по проверке фактов (фактчекер). 
Проанализируй текст пользователя и дай подробную оценку.

Отвечай ТОЛЬКО на русском языке в следующем формате:

📊 **ОЦЕНКА ДОСТОВЕРНОСТИ:** (выбери одно: Правда / Неправда / Частично правда / Недостаточно данных / Сомнительно)

🎯 **ВЕРДИКТ:** (одно предложение с итогом)

🔍 **ДЕТАЛЬНЫЙ АНАЛИЗ:**
• (разбор каждого ключевого утверждения)
• (что подтверждается, что опровергается)

📎 **ИСТОЧНИКИ И ОБОСНОВАНИЕ:**
• (если известны источники — укажи)
• (если нет — объясни почему)

⚠️ **ПРЕДУПРЕЖДЕНИЯ:** (если есть манипуляции, пропаганда, нелогичности)

💡 **РЕКОМЕНДАЦИЯ:** (что делать с этой информацией)

Если информации недостаточно для вывода — честно скажи об этом.""",},
                {"role": "user", "content": f"Проанализируй на достоверность следующий текст:\n\n{user_text}"}
            ],
            temperature=0.3
        )
        
        analysis = response.choices[0].message.content
        await message.answer(f"✅ **Результат проверки:**\n\n{analysis}", parse_mode="Markdown")
        
    except Exception as e:
        await message.answer(f"❌ **Ошибка при анализе:** {str(e)}\n\nПопробуй позже или проверь API ключ OpenAI.", parse_mode="Markdown")
    
    await state.clear()
    await message.answer("Что делаем дальше?", reply_markup=main_menu())


        parse_mode="Markdown"
    )
    await state.set_state(InputStates.waiting_username)
    await callback.answer()

@dp.message(InputStates.waiting_username)
async def sherlock_search(message: types.Message, state: FSMContext):
    username = message.text.strip().replace("@", "")
    await message.answer(f"🔎 Ищу профили для `{username}`... Это может занять 10-20 секунд.", parse_mode="Markdown")
    
    # Список популярных платформ для проверки
    platforms = {
        "Instagram": f"https://instagram.com/{username}",
        "Twitter/X": f"https://twitter.com/{username}",
        "VK": f"https://vk.com/{username}",
        "TikTok": f"https://tiktok.com/@{username}",
        "YouTube": f"https://youtube.com/@{username}",
        "GitHub": f"https://github.com/{username}",
        "Reddit": f"https://reddit.com/user/{username}",
        "Telegram": f"https://t.me/{username}",
        "Facebook": f"https://facebook.com/{username}",
        "LinkedIn": f"https://linkedin.com/in/{username}",
        "Pinterest": f"https://pinterest.com/{username}",
        "Twitch": f"https://twitch.tv/{username}",
        "Snapchat": f"https://snapchat.com/add/{username}",
        "Discord": f"https://discord.com/users/{username}",
        "Medium": f"https://medium.com/@{username}"
    }
    
    found = []
    not_found = []
    
    # Проверяем каждую платформу
    import aiohttp
    async with aiohttp.ClientSession() as session:
        for platform, url in platforms.items():
            try:
                async with session.get(url, timeout=5) as response:
                    if response.status == 200:
                        found.append(f"✅ **{platform}:** {url}")
                    else:
                        not_found.append(platform)
            except:
                not_found.append(platform)
    
    # Формируем результат
    if found:
        result = f"🔍 **Результаты поиска для `{username}`:**\n\n"
        result += "\n".join(found)
        result += f"\n\n📊 **Найдено профилей:** {len(found)} из {len(platforms)}"
    else:
        result = f"❌ **Профили для `{username}` не найдены** ни на одной из проверенных платформ.\n\nВозможно, профиль скрыт или не существует."
    
    await message.answer(result, parse_mode="Markdown", disable_web_page_preview=True)
    await state.clear()
    await message.answer("Что делаем дальше?", reply_markup=main_menu())


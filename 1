@dp.message(InputStates.waiting_phone)
async def phone_analysis(message: types.Message, state: FSMContext):
    phone = message.text.strip()
    await message.answer("📊 Анализирую номер...")
    
    try:
        # Парсим номер
        parsed = phonenumbers.parse(phone, None)
        
        if not phonenumbers.is_valid_number(parsed):
            await message.answer("❌ **Неверный формат номера**\n\nПроверь номер и попробуй снова.\nПример: +77771234567", parse_mode="Markdown")
            await state.clear()
            await message.answer("Что делаем дальше?", reply_markup=main_menu())
            return
        
        # Получаем информацию
        country = geocoder.description_for_number(parsed, "ru")
        operator = carrier.name_for_number(parsed, "ru")
        time_zones = timezone.time_zones_for_number(parsed)
        formatted_int = phonenumbers.format_number(parsed, phonenumbers.PhoneNumberFormat.INTERNATIONAL)
        formatted_nat = phonenumbers.format_number(parsed, phonenumbers.PhoneNumberFormat.NATIONAL)
        
        # Определяем тип номера
        number_type = "Мобильный" if operator else "Стационарный/Неизвестно"
        
        result = f"""
📞 **Результат анализа номера**

**Номер (международный):** `{formatted_int}`
**Номер (национальный):** `{formatted_nat}`
**Страна:** {country}
**Оператор:** {operator if operator else 'Не определен (возможно стационарный или виртуальный)'}
**Тип номера:** {number_type}
**Временная зона:** {', '.join(time_zones) if time_zones else 'Не определена'}
**Валидность:** ✅ Да

---
⚠️ *По законам стран СНГ, определение владельца номера без его согласия запрещено. Я показываю только техническую информацию.*
"""
        await message.answer(result, parse_mode="Markdown")
        
    except phonenumbers.NumberParseException as e:
        await message.answer(f"❌ **Ошибка:** Неверный формат номера.\n\nПример правильного ввода: +77771234567", parse_mode="Markdown")
    except Exception as e:
        await message.answer(f"❌ **Ошибка:** {str(e)}", parse_mode="Markdown")
    
    await state.clear()
    await message.answer("Что делаем дальше?", reply_markup=main_menu())


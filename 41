    parts = callback.data.split("_")
    action = parts[1]
    country = parts[2]
    await state.update_data(country=country)
    
    actions_map = {
        "phone": ("enter_phone", States.waiting_phone, False, "phone"),
        "fio": ("enter_fio", States.waiting_fio, False, "name"),
        "email": ("enter_email", States.waiting_email, True, "email"),

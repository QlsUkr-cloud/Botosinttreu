    def recursive_search(self, country_code, start_query, query_type="phone", max_depth=3):
        """
        РЕКУРСИВНИЙ ПОШУК - автоматично шукає всі зв'язки
        номер → ФІО → email → tg → адреса → і т.д.
        """
        all_data = {
            "phones": set(), "names": set(), "nicknames": set(), "emails": set(),
            "iin": set(), "addresses": set(), "tg_ids": set(), "tg_usernames": set(),
            "vk": set(), "social": set(), "cards": set(), "jobs": set(),
            "relatives": set(), "dates": set(), "tiktok": set(), "ip": set(), "auto": set()
        }
        all_rows = []
        queue = [(start_query, query_type, 0)]
        processed = set()
        iterations = []
        
        iteration_num = 1
        while queue and iteration_num <= max_depth * 10:
            query, qtype, depth = queue.pop(0)
            
            if depth > max_depth:
                continue
            
            key = f"{qtype}:{query}"
            if key in processed:
                continue
            processed.add(key)
            
            # Запам'ятовуємо ітерацію
            iterations.append(f"📌 Ітерація {iteration_num} (глибина {depth}): пошук за {qtype}='{query[:50]}'")
            
            # Шукаємо
            rows = self.search_in_files(country_code, query, qtype)
            
            for row in rows:
                if tuple(row) not in all_rows:
                    all_rows.append(tuple(row))
            
            # Витягуємо дані
            new_data = self.extract_all_data(rows)
            
            for key in all_data:
                all_data[key].update(new_data.get(key, []))
            
            # Додаємо нові запити
            if depth < max_depth:
                for phone in list(new_data.get("phones", []))[:3]:
                    if f"phone:{phone}" not in processed:
                        queue.append((phone, "phone", depth + 1))
                for name in list(new_data.get("names", []))[:3]:
                    if f"name:{name}" not in processed:
                        queue.append((name, "name", depth + 1))
                for email in list(new_data.get("emails", []))[:2]:
                    if f"email:{email}" not in processed:
                        queue.append((email, "email", depth + 1))
                for tg in list(new_data.get("tg_usernames", []))[:2]:
                    if f"tg:{tg}" not in processed:
                        queue.append((tg, "tg", depth + 1))
            
            iteration_num += 1
        
        result = {k: list(v)[:15] for k, v in all_data.items()}
        result["total_records"] = len(all_rows)
        result["total_iterations"] = iteration_num - 1
        result["iterations"] = iterations
        
        return result
    
    def deep_osint_analysis(self, country_code, query, query_type="phone", max_depth=2):
        """Глибокий аналіз (для сумісності)"""
        return self.recursive_search(country_code, query, query_type, max_depth)


@dp.callback_query(lambda c: c.data.startswith("dork_"))
async def handle_dork(callback: types.CallbackQuery, state: States):
    dork_type = callback.data.split("_")[1]
    await state.update_data(dork_type=dork_type)
    prompts = {
        "person": "👤 Введіть ПІБ або username:",
        "email": "📧 Введіть email:",
        "docs": "📂 Введіть ключове слово:",
        "tg": "💬 Введіть Telegram:",
        "secret": "🔐 Введіть сайт:"
    }
    await callback.message.edit_text(prompts.get(dork_type, "Введіть запит:"))
    await state.set_state(States.waiting_dork)
    await callback.answer()

@dp.message(States.waiting_dork)
async def process_dork(message: types.Message, state: States):
    query = message.text.strip()
    data = await state.get_data()
    dork_type = data.get("dork_type", "person")
    templates = {
        "person": [f'"{query}" site:instagram.com', f'"{query}" site:t.me', f'"{query}" site:vk.com'],
        "email": [f'"{query}" filetype:pdf', f'"{query}" site:pastebin.com'],
        "docs": [f'filetype:pdf "{query}"', f'filetype:xls "{query}"'],
        "tg": [f'site:t.me "{query}"', f'"@{query}"'],
        "secret": [f'site:{query} filetype:env', f'site:{query} "password"']
    }
    result = "🔎 **Google Dork**\n\n" + "\n".join(templates.get(dork_type, []))
    await message.answer(result[:4000])
    await state.clear()
    await message.answer(get_text(message.from_user.id, "main_menu"), reply_markup=country_keyboard(message.from_user.id))

@dp.message(States.waiting_url)
async def process_webarchive(message: types.Message, state: States):
    user_id = message.from_user.id
    url = message.text.strip()
    await message.answer("📁 Шукаю архів...")
    try:
        encoded = urllib.parse.quote(url, safe='')
        async with aiohttp.ClientSession() as session:
            async with session.get(f"https://archive.org/wayback/available?url={encoded}", timeout=15) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    if data.get("archived_snapshots"):
                        snapshot = data["archived_snapshots"]["closest"]
                        await message.answer(f"📁 **Архівна копія:**\n{snapshot['url']}")
                    else:
                        await message.answer("❌ Архівів не знайдено")
                else:
                    await message.answer("❌ Помилка")
    except Exception as e:
        await message.answer(f"❌ {str(e)[:100]}")
    await state.clear()
    await message.answer(get_text(user_id, "main_menu"), reply_markup=country_keyboard(user_id))

@dp.message(States.waiting_text)
async def process_factcheck(message: types.Message, state: States):
    user_id = message.from_user.id
    text = message.text.strip()
    if len(text) < 10:
        await message.answer("❌ Занадто коротко")
    else:
        await message.answer("🧠 Аналізую...")
        try:
            response = await openai_client.chat.completions.create(
                model="gpt-4o-mini",
                messages=[{"role": "user", "content": f"Перевір факт: {text}"}]
            )
            await message.answer(f"✅ **Результат:**\n\n{response.choices[0].message.content}")
        except Exception as e:
            await message.answer(f"❌ {str(e)[:100]}")
    await state.clear()
    await message.answer(get_text(user_id, "main_menu"), reply_markup=country_keyboard(user_id))

@dp.message(States.waiting_phone)

@dp.message(States.waiting_promo)
async def process_promo(message: types.Message, state: States):
    user_id = message.from_user.id
    code = message.text.strip().upper()
    data = await state.get_data()
    next_action = data.get("next_action")
    country = data.get("country")
    
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute("SELECT level, used_by FROM promocodes WHERE code = ?", (code,))
    promo = cursor.fetchone()
    conn.close()
    
    if not promo:
        await message.answer(get_text(user_id, "promo_invalid"))
    elif promo[1] is not None:
        await message.answer(get_text(user_id, "promo_already_used"))
    else:
        level = promo[0]
        activate_promo(user_id, code, level)
        await message.answer(get_text(user_id, "promo_activated") + f"\n📅 Рівень: {level}")
        
        if next_action and country:
            await state.update_data(country=country)
            if next_action == "recursive":
                await message.answer(get_text(user_id, "enter_phone"))
                await state.set_state(States.waiting_phone)
                await state.update_data(search_type="phone", recursive_mode=True)
            elif next_action == "email":
                await message.answer(get_text(user_id, "enter_email"))
                await state.set_state(States.waiting_email)
                await state.update_data(search_type="email")
            elif next_action == "tg":
                await message.answer(get_text(user_id, "enter_tg"))
                await state.set_state(States.waiting_tg)
                await state.update_data(search_type="tg")
            elif next_action == "address":
                await message.answer(get_text(user_id, "enter_address"))
                await state.set_state(States.waiting_address)
                await state.update_data(search_type="address")
            elif next_action == "tiktok":
                await message.answer(get_text(user_id, "enter_tiktok"))
                await state.set_state(States.waiting_tiktok)
                await state.update_data(search_type="tiktok")
            elif next_action == "ip":
                await message.answer(get_text(user_id, "enter_ip"))
                await state.set_state(States.waiting_ip)
                await state.update_data(search_type="ip")
            elif next_action == "auto":
                await message.answer(get_text(user_id, "enter_auto"))
                await state.set_state(States.waiting_auto)
                await state.update_data(search_type="auto")

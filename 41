        "auto": ("enter_auto", States.waiting_auto, True, "auto"),
        "recursive": ("enter_phone", States.waiting_phone, True, "recursive")
    }
    
    if action in actions_map:
        text_key, state_name, need_promo, search_type = actions_map[action]
        if need_promo and check_user_level(user_id) == "USER":
            await callback.message.edit_text(get_text(user_id, "promo_required"))
            await state.set_state(States.waiting_promo)
            await state.update_data(next_action=action, country=country)
        else:
            await callback.message.edit_text(get_text(user_id, text_key))
            await state.set_state(state_name)
            await state.update_data(search_type=search_type)
            if action == "recursive":
                await state.update_data(recursive_mode=True)
    await callback.answer()

# =============== ПОШУК (УНІВЕРСАЛЬНА ФУНКЦІЯ) ===============
async def perform_search(message: types.Message, state: States):
    user_id = message.from_user.id
    query = message.text.strip()
    data = await state.get_data()
    country = data.get("country")
    search_type = data.get("search_type", "phone")
    recursive_mode = data.get("recursive_mode", False)
    
    if not country:
        await message.answer(get_text(user_id, "main_menu"), reply_markup=country_keyboard(user_id))
        await state.clear()
        return
    
    if recursive_mode:
        # Рекурсивний пошук
        await message.answer(get_text(user_id, "recursive_searching", iterations="⏳ Зачекайте..."))
        
        result = await asyncio.to_thread(searcher.recursive_search, country, query, search_type, 3)
        inc_search(user_id)
        add_history(user_id, query, "recursive", country, result.get("total_records", 0))
        
        # Показуємо ітерації
        iterations_text = "\n".join(result.get("iterations", [])[:10])
        await message.answer(get_text(user_id, "recursive_searching", iterations=iterations_text))
        
        # Показуємо результат
        result_text = get_text(user_id, "recursive_result",
            query=query,
            depth=result.get("total_iterations", 0),
            total_records=result.get("total_records", 0),
            phones=result.get("phones", []),
            names=result.get("names", []),
            nicknames=result.get("nicknames", []),
            emails=result.get("emails", []),
            iin=result.get("iin", []),
            addresses=result.get("addresses", []),
            tg_usernames=result.get("tg_usernames", []),
            tiktok=result.get("tiktok", []),
            ip=result.get("ip", []),
            auto=result.get("auto", [])
        )
        
        if len(result_text) > 4000:
            for i in range(0, len(result_text), 4000):
                await message.answer(result_text[i:i+4000])
        else:
            await message.answer(result_text)
    else:
        # Звичайний пошук
        await message.answer(get_text(user_id, "searching"))
        results = await asyncio.to_thread(searcher.search_in_files, country, query, search_type)
        inc_search(user_id)
        add_history(user_id, query, search_type, country, len(results))
        
        if results:
            await message.answer(get_text(user_id, "found", count=len(results)))
            for row in results[:10]:
                row_text = " | ".join(str(cell) for cell in row if cell)
                if len(row_text) > 500:
                    row_text = row_text[:500] + "..."
                await message.answer(f"📋 {row_text}")
            if len(results) > 10:
                await message.answer(f"📊 Показано 10 з {len(results)} результатів")
        else:
            await message.answer(get_text(user_id, "not_found"))
    
    await state.clear()
    await message.answer(get_text(user_id, "main_menu"), reply_markup=country_keyboard(user_id))


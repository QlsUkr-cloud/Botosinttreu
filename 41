USERS_DB = "users.db"
STATS_DB = "stats.db"

def init_dbs():
    """Ініціалізація баз даних"""
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    
    # Створюємо таблицю users з усіма потрібними полями
    cursor.execute('''CREATE TABLE IF NOT EXISTS users (
        user_id INTEGER PRIMARY KEY,
        language TEXT DEFAULT 'uk',
        user_level TEXT DEFAULT 'USER',
        promo_code TEXT,
        promo_expiry TEXT,
        search_count INTEGER DEFAULT 0,
        registered_at TEXT
    )''')
    
    # Перевіряємо чи є всі колонки
    cursor.execute("PRAGMA table_info(users)")
    columns = [col[1] for col in cursor.fetchall()]
    
    if 'search_count' not in columns:
        cursor.execute("ALTER TABLE users ADD COLUMN search_count INTEGER DEFAULT 0")
    if 'user_level' not in columns:
        cursor.execute("ALTER TABLE users ADD COLUMN user_level TEXT DEFAULT 'USER'")
    if 'promo_code' not in columns:
        cursor.execute("ALTER TABLE users ADD COLUMN promo_code TEXT")
    if 'promo_expiry' not in columns:
        cursor.execute("ALTER TABLE users ADD COLUMN promo_expiry TEXT")
    if 'registered_at' not in columns:
        cursor.execute("ALTER TABLE users ADD COLUMN registered_at TEXT")
    
    cursor.execute('''CREATE TABLE IF NOT EXISTS search_history (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER, 
        query TEXT, 
        query_type TEXT, 
        country TEXT, 
        result_count INTEGER, 
        search_date TEXT
    )''')
    
    cursor.execute('''CREATE TABLE IF NOT EXISTS promocodes (
        code TEXT PRIMARY KEY,
        level TEXT DEFAULT 'PREMIUM',
        used_by INTEGER,
        used_at TEXT,
        created_by INTEGER,
        created_at TEXT
    )''')
    
    conn.commit()
    conn.close()
    
    # База статистики
    conn = sqlite3.connect(STATS_DB)
    cursor = conn.cursor()
    cursor.execute('''CREATE TABLE IF NOT EXISTS search_stats (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        query TEXT UNIQUE,
        query_type TEXT,
        search_count INTEGER DEFAULT 1,
        last_searched TEXT,
        found_count INTEGER DEFAULT 0
    )''')
    conn.commit()
    conn.close()
    
    print("✅ Бази даних ініціалізовано")

init_dbs()

# =============== ФУНКЦІЇ РОБОТИ З БАЗОЮ ===============
def get_user(user_id: int) -> Optional[Dict]:
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute("SELECT language, user_level, promo_code, promo_expiry, search_count, registered_at FROM users WHERE user_id = ?", (user_id,))
    r = cursor.fetchone()
    conn.close()
    if r:
        return {
            "language": r[0], 
            "user_level": r[1], 
            "promo_code": r[2], 
            "promo_expiry": r[3],
            "search_count": r[4],
            "registered_at": r[5]
        }
    return None

def save_user(user_id: int, lang: str = "uk"):
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute('''INSERT OR REPLACE INTO users (user_id, language, user_level, search_count, registered_at) 
                     VALUES (?, ?, 'USER', COALESCE((SELECT search_count FROM users WHERE user_id = ?), 0), ?)''', 
                   (user_id, lang, user_id, datetime.now().isoformat()))
    conn.commit()
    conn.close()

def activate_promo(user_id: int, code: str, level: str):
    expiry = (datetime.now() + timedelta(days=30)).isoformat()
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute("UPDATE users SET promo_code = ?, promo_expiry = ?, user_level = ? WHERE user_id = ?", 
                   (code, expiry, level, user_id))
    conn.commit()
    conn.close()
    
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute("UPDATE promocodes SET used_by = ?, used_at = ? WHERE code = ?", 
                   (user_id, datetime.now().isoformat(), code))
    conn.commit()
    conn.close()

def check_user_level(user_id: int) -> str:
    user = get_user(user_id)
    if user and user.get("promo_expiry"):
        if datetime.fromisoformat(user["promo_expiry"]) > datetime.now():
            return user.get("user_level", "USER")
    return "USER"

def add_history(user_id: int, query: str, qtype: str, country: str, count: int):
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute('''INSERT INTO search_history (user_id, query, query_type, country, result_count, search_date) 
                     VALUES (?,?,?,?,?,?)''',
                   (user_id, query, qtype, country, count, datetime.now().isoformat()))
    conn.commit()
    conn.close()
    
    conn = sqlite3.connect(STATS_DB)
    cursor = conn.cursor()
    cursor.execute('''INSERT INTO search_stats (query, query_type, search_count, last_searched, found_count) 
                     VALUES (?, ?, 1, ?, ?) 
                     ON CONFLICT(query) DO UPDATE SET 
                     search_count = search_count + 1, last_searched = ?, found_count = ?''',
                   (query, qtype, datetime.now().isoformat(), count, datetime.now().isoformat(), count))
    conn.commit()
    conn.close()

def inc_search(user_id: int):
    conn = sqlite3.connect(USERS_DB)
    cursor = conn.cursor()
    cursor.execute("UPDATE users SET search_count = search_count + 1 WHERE user_id = ?", (user_id,))
    conn.commit()
    conn.close()


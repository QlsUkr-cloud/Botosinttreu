# =============== ОБРОБНИКИ ===============
class States(StatesGroup):
    waiting_phone = State()
    waiting_fio = State()
    waiting_email = State()
    waiting_promo = State()

@dp.message(Command("start"))
async def start(message: types.Message):
    user_id = message.from_user.id
    if not get_user(user_id):
        save_user(user_id)
    await message.answer(get_text(user_id, "start"), reply_markup=country_keyboard(user_id))

@dp.callback_query(lambda c: c.data == "back")
async def back_to_countries(callback: types.CallbackQuery, state: States):
    user_id = callback.from_user.id
    await state.clear()
    await callback.message.edit_text(get_text(user_id, "main_menu"), reply_markup=country_keyboard(user_id))
    await callback.answer()

@dp.callback_query(lambda c: c.data.startswith("country_"))
async def select_country(callback: types.CallbackQuery, state: States):
    user_id = callback.from_user.id
    country_code = callback.data.split("_")[1]
    await state.update_data(country=country_code)
    await callback.message.edit_text(
        f"{COUNTRIES[country_code]}\n\n{get_text(user_id, 'main_menu')}",
        reply_markup=action_keyboard(user_id, country_code)
    )
    await callback.answer()

@dp.callback_query(lambda c: c.data.startswith("action_"))
async def handle_action(callback: types.CallbackQuery, state: States):
    user_id = callback.from_user.id
    parts = callback.data.split("_")
    action = parts[1]
    country = parts[2]
    
    await state.update_data(country=country)
    
    if action == "phone":
        await callback.message.edit_text(get_text(user_id, "enter_phone"))
        await state.set_state(States.waiting_phone)
    elif action == "fio":
        await callback.message.edit_text(get_text(user_id, "enter_fio"))
        await state.set_state(States.waiting_fio)
    elif action == "email":
        if not check_promo(user_id):
            await callback.message.edit_text(get_text(user_id, "promo_required"))
            await state.set_state(States.waiting_promo)
            await state.update_data(next_action="email")
        else:
            await callback.message.edit_text(get_text(user_id, "enter_email"))
            await state.set_state(States.waiting_email)
    elif action == "deep":
        if not check_promo(user_id):
            await callback.message.edit_text(get_text(user_id, "promo_required"))
            await state.set_state(States.waiting_promo)
            await state.update_data(next_action="deep")
        else:
            await callback.message.edit_text(get_text(user_id, "enter_phone") + "\n\n(або введіть ФІО чи Email)")
            await state.set_state(States.waiting_phone)
            await state.update_data(deep_mode=True)
    
    await callback.answer()

@dp.message(States.waiting_phone)
async def search_phone(message: types.Message, state: States):
    user_id = message.from_user.id
    query = message.text.strip()
    data = await state.get_data()
    country = data.get("country")
    deep_mode = data.get("deep_mode", False)
    
    if not country:
        await message.answer(get_text(user_id, "main_menu"), reply_markup=country_keyboard(user_id))
        await state.clear()
        return
    
    country_name = COUNTRIES.get(country, country)
    
    if deep_mode:
        await message.answer(get_text(user_id, "deep_searching", query=query))
        result = await asyncio.to_thread(searcher.deep_search, country, query, "phone", 3)
        
        inc_search(user_id)
        add_history(user_id, query, "deep", country, result["total"])
        
        phones = ", ".join(result["info"]["phones"][:10]) if result["info"]["phones"] else "немає"
        names = ", ".join(result["info"]["names"][:10]) if result["info"]["names"] else "немає"
        emails = ", ".join(result["info"]["emails"][:5]) if result["info"]["emails"] else "немає"
        iin = ", ".join(result["info"]["iin"][:5]) if result["info"]["iin"] else "немає"
        addresses = ", ".join(result["info"]["addresses"][:5]) if result["info"]["addresses"] else "немає"
        
        await message.answer(get_text(user_id, "deep_result",
            total=result["total"],
            phones=phones, names=names, emails=emails, iin=iin, addresses=addresses
        ))
        

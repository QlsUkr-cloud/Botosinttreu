class FastSearcher:
    def __init__(self):
        self.index = {}  # {країна: {номер: [рядки], фіо: [рядки], email: [рядки]}}
        self.loaded = False
    
    def load_all(self):
        """Завантажує всі бази в пам'ять (швидкий доступ)"""
        print("📂 Завантаження баз даних...")
        for country_code in COUNTRIES:
            self.index[country_code] = {"phones": {}, "names": {}, "emails": [], "raw": []}
            folder = os.path.join(DATABASES_DIR, country_code)
            if not os.path.exists(folder):
                continue
            
            for file in os.listdir(folder):
                if file.endswith(('.csv', '.txt')):
                    path = os.path.join(folder, file)
                    try:
                        with open(path, 'r', encoding='utf-8', errors='ignore') as f:
                            sample = f.read(1024)
                            f.seek(0)
                            delim = ';' if ';' in sample else ','
                            reader = csv.reader(f, delimiter=delim)
                            for row in reader:
                                if row:
                                    self.index[country_code]["raw"].append(row)
                                    # Індексація
                                    for cell in row:
                                        cell_str = str(cell).strip()
                                        # Телефони
                                        phone_clean = re.sub(r'\D', '', cell_str)
                                        if len(phone_clean) >= 7:
                                            if phone_clean not in self.index[country_code]["phones"]:
                                                self.index[country_code]["phones"][phone_clean] = []
                                            self.index[country_code]["phones"][phone_clean].append(row)
                                        # Імена (2+ слова з великої літери)
                                        if re.match(r'[А-ЯЁІЇЄ][а-яёіїє]+\s+[А-ЯЁІЇЄ][а-яёіїє]+', cell_str):
                                            name_lower = cell_str.lower()
                                            if name_lower not in self.index[country_code]["names"]:
                                                self.index[country_code]["names"][name_lower] = []
                                            self.index[country_code]["names"][name_lower].append(row)
                                        # Email
                                        if '@' in cell_str and '.' in cell_str:
                                            self.index[country_code]["emails"].append((cell_str.lower(), row))
                        print(f"   ✅ {country_code}: {os.path.basename(file)}")
                    except Exception as e:
                        print(f"   ❌ Помилка {file}: {e}")
        self.loaded = True
        print("✅ Всі бази завантажено!")
    
    def search_phone(self, country, phone):
        """Швидкий пошук за номером"""
        if not self.loaded:
            self.load_all()
        phone_clean = re.sub(r'\D', '', phone)
        results = []
        # Точний збіг
        if phone_clean in self.index.get(country, {}).get("phones", {}):
            results.extend(self.index[country]["phones"][phone_clean])
        # Пошук по закінченню
        for p, rows in self.index.get(country, {}).get("phones", {}).items():
            if p.endswith(phone_clean[-7:]) and len(p) >= 7:
                results.extend(rows)
        return list({tuple(r) for r in results})[:50]
    
    def search_name(self, country, name):
        """Швидкий пошук за ФІО"""
        if not self.loaded:
            self.load_all()
        name_lower = name.lower().strip()
        results = []
        # Точний збіг
        if name_lower in self.index.get(country, {}).get("names", {}):
            results.extend(self.index[country]["names"][name_lower])
        # Частковий збіг
        for n, rows in self.index.get(country, {}).get("names", {}).items():
            if name_lower in n or all(p in n for p in name_lower.split()):
                results.extend(rows)
        return list({tuple(r) for r in results})[:50]
    
    def search_email(self, country, email):
        """Швидкий пошук за email"""
        if not self.loaded:
            self.load_all()
        email_lower = email.lower()
        results = []
        for e, row in self.index.get(country, {}).get("emails", []):
            if email_lower in e or e == email_lower:
                results.append(row)
        return list({tuple(r) for r in results})[:50]
    
    def extract_all_info(self, country, rows):
        """Витягує всю інформацію з знайдених рядків"""
        all_phones = set()
        all_names = set()
        all_emails = set()
        all_iin = set()
        all_addresses = set()
        
        for row in rows:
            for cell in row:
                cell_str = str(cell).strip()
                # Телефони
                phone_clean = re.sub(r'\D', '', cell_str)
                if len(phone_clean) >= 7:
                    all_phones.add(phone_clean)
                # Імена
                if re.match(r'[А-ЯЁІЇЄ][а-яёіїє]+\s+[А-ЯЁІЇЄ][а-яёіїє]+', cell_str):
                    all_names.add(cell_str)
                # Email
                if '@' in cell_str and '.' in cell_str:
                    all_emails.add(cell_str.lower())
                # ІІН (12 цифр для КЗ, 10 для УА)
                if re.match(r'^\d{10}$', cell_str) or re.match(r'^\d{12}$', cell_str):
                    all_iin.add(cell_str)
                # Адреса
                if any(word in cell_str.lower() for word in ['вул', 'ул', 'просп', 'пр', 'бульв', 'місто', 'город', 'село']):
                    all_addresses.add(cell_str)
        
        return {
            "phones": list(all_phones),
            "names": list(all_names),
            "emails": list(all_emails),
            "iin": list(all_iin),
            "addresses": list(all_addresses)
        }
    
    def deep_search(self, country, start_query, query_type="phone", max_depth=3):
        """Глибокий рекурсивний пошук"""
        found_data = {}
        all_rows = []
        queue = [(start_query, query_type, 0)]
        processed = set()
        
        while queue:
            query, qtype, depth = queue.pop(0)
            if depth > max_depth:
                continue
            
            key = f"{qtype}:{query}"
            if key in processed:
                continue
            processed.add(key)
            
            # Пошук
            if qtype == "phone":
                rows = self.search_phone(country, query)
            elif qtype == "email":
                rows = self.search_email(country, query)
            else:
                rows = self.search_name(country, query)
            
            for row in rows:
                if tuple(row) not in all_rows:
                    all_rows.append(tuple(row))
            
            # Витягуємо нові дані для подальшого пошуку
            info = self.extract_all_info(country, rows)
            
            for phone in info["phones"][:5]:
                if f"phone:{phone}" not in processed:
                    queue.append((phone, "phone", depth + 1))
            for name in info["names"][:5]:
                if f"name:{name}" not in processed:
                    queue.append((name, "name", depth + 1))
            for email in info["emails"][:3]:
                if f"email:{email}" not in processed:
                    queue.append((email, "email", depth + 1))
        
        return {
            "total": len(all_rows),
            "rows": [list(r) for r in all_rows],
            "info": self.extract_all_info(country, all_rows)
        }


# =============== КЛАС ДЛЯ ПОШУКУ ПО БАЗАХ ===============
class DatabaseSearcher:
    def __init__(self, db_path):
        self.db_path = db_path
        self.databases_info = {}
        self.loaded = False
    
    def scan_databases(self):
        if not os.path.exists(self.db_path):
            os.makedirs(self.db_path)
            return {}
        
        databases = {}
        files = []
        
        for ext in ['*.csv', '*.txt', '*.xlsx']:
            files.extend(glob.glob(os.path.join(self.db_path, ext)))
        
        for file_path in files:
            file_name = os.path.basename(file_path)
            try:
                file_size = os.path.getsize(file_path)
                size_mb = file_size / (1024 * 1024)
                
                databases[file_name] = {
                    'path': file_path,
                    'size_mb': round(size_mb, 2),
                    'type': file_path.split('.')[-1]
                }
                print(f"📁 Знайдено базу: {file_name} ({size_mb:.2f} МБ)")
            except Exception as e:
                print(f"❌ Помилка: {e}")
        
        self.databases_info = databases
        self.loaded = True
        return databases
    
    def search_in_file(self, file_path, query, search_type="phone"):
        """Пошук в файлі: за номером або за ФІО"""
        results = []
        
        try:
            with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:
                sample = f.read(1024)
                f.seek(0)
                delimiter = ';' if ';' in sample else ','
                reader = csv.reader(f, delimiter=delimiter)
                
                for row_num, row in enumerate(reader):
                    if row_num > 50000:
                        break
                    
                    row_text = " ".join(row).lower()
                    
                    if search_type == "phone":
                        query_clean = re.sub(r'\D', '', query)
                        for cell in row:
                            cell_clean = re.sub(r'\D', '', str(cell))
                            if query_clean == cell_clean or cell_clean.endswith(query_clean[-7:]):
                                results.append({
                                    'row': row_num + 1,
                                    'full_row': row,
                                    'data': row
                                })
                                if len(results) >= 10:
                                    return results
                    else:  # Поиск по ФИО
                        if query.lower() in row_text:
                            results.append({
                                'row': row_num + 1,
                                'full_row': row,
                                'data': row
                            })
                            if len(results) >= 10:
                                return results
        
        except Exception as e:
            pass
        
        return results
    
    def search_phone(self, phone_number):
        """Пошук номера телефону"""
        if not self.loaded:
            self.scan_databases()
        
        if not self.databases_info:
            return None
        
        all_results = {}
        for name, info in self.databases_info.items():
            results = self.search_in_file(info['path'], phone_number, "phone")
            if results:
                all_results[name] = {
                    'info': info,
                    'matches': results,
                    'count': len(results)
                }
        
        return all_results if all_results else None
    
    def search_name(self, name):
        """Пошук за ФІО"""
        if not self.loaded:
            self.scan_databases()
        
        if not self.databases_info:
            return None
        
        all_results = {}
        for name_db, info in self.databases_info.items():
            results = self.search_in_file(info['path'], name, "name")
            if results:
                all_results[name_db] = {
                    'info': info,
                    'matches': results,
                    'count': len(results)
                }
        
        return all_results if all_results else None


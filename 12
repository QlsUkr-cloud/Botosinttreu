    await state.update_data(dork_type=dork_type)
    
    prompts = {
        "person": "👤 Введи username для поиска:",
        "email": "📧 Введи email или домен:",
        "docs": "📂 Введи ключевое слово:",
        "admin": "💀 Введи сайт:",
        "secret": "🔐 Введи сайт:"
    }
    
    await callback.message.edit_text(prompts.get(dork_type, "Введи запрос:"), parse_mode="Markdown")
    await state.set_state(InputStates.waiting_dork_query)
    await callback.answer()

@dp.message(InputStates.waiting_dork_query)
async def process_dork(message: types.Message, state: FSMContext):
    query = message.text.strip()
    user_data = await state.get_data()
    dork_type = user_data.get("dork_type", "person")
    
    templates = {
        "person": [f'"{query}" site:instagram.com', f'"{query}" site:t.me', f'"{query}" site:facebook.com'],
        "email": [f'"{query}" filetype:pdf', f'"{query}" site:pastebin.com'],
        "docs": [f'filetype:pdf "{query}"', f'filetype:xls "{query}"'],
        "admin": [f'site:{query} inurl:admin', f'site:{query} inurl:login'],
        "secret": [f'site:{query} filetype:env', f'site:{query} filetype:json "api"']
    }
    
    dorks = templates.get(dork_type, [])
    result_text = f"🔎 **Google Dork для `{query}`**\n\n" + "\n".join([f"• `{d}`" for d in dorks])
    
    await message.answer(result_text[:4000], parse_mode="Markdown")
    await state.clear()
    await message.answer("Что дальше?", reply_markup=main_menu())


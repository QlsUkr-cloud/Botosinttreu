def is_whitelisted(username=None, phone=None, user_id=None):
    for entry in whitelist.values():
        if username and entry.get("username") == username:
            return True
        if phone and entry.get("phone") == phone:
            return True
        if user_id and entry.get("user_id") == user_id:
            return True
    return False

def add_to_whitelist(user_id, username, phone, promo_code):
    whitelist[str(user_id)] = {
        "user_id": user_id,
        "username": username,
        "phone": phone,
        "added_at": datetime.now().isoformat(),
        "promo_code": promo_code
    }
    save_whitelist(whitelist)

# =============== КЛАС ДЛЯ ПОШУКУ ПО БАЗАХ ===============
class DatabaseSearcher:
    def __init__(self, db_path):
        self.db_path = db_path
        self.databases_info = {}
        self.loaded = False
    
    def scan_databases(self):
        """Сканує папку databases і повертає список файлів"""
        if not os.path.exists(self.db_path):
            os.makedirs(self.db_path)
            return {}
        
        databases = {}
        files = []
        
        for ext in ['*.csv', '*.txt', '*.xlsx']:
            files.extend(glob.glob(os.path.join(self.db_path, ext)))
        
        for file_path in files:
            file_name = os.path.basename(file_path)
            try:
                file_size = os.path.getsize(file_path)
                size_mb = file_size / (1024 * 1024)
                
                databases[file_name] = {
                    'path': file_path,
                    'size_mb': round(size_mb, 2),
                    'type': file_path.split('.')[-1]
                }
                print(f"📁 Знайдено базу: {file_name} ({size_mb:.2f} МБ)")
            except Exception as e:
                print(f"❌ Помилка: {e}")
        
        self.databases_info = databases
        self.loaded = True
        return databases
    
    def search_in_file(self, file_path, phone_number):
        """Пошук номера в одному файлі"""
        phone_clean = re.sub(r'\D', '', phone_number)
        phone_last7 = phone_clean[-7:] if len(phone_clean) >= 7 else phone_clean
        
        results = []
        
        try:
            if file_path.endswith('.csv'):
                with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:
                    sample = f.read(1024)
                    f.seek(0)
                    delimiter = ';' if ';' in sample else ','
                    reader = csv.reader(f, delimiter=delimiter)
                    for row_num, row in enumerate(reader):
                        if row_num > 50000:
                            break
                        for cell in row:
                            cell_str = str(cell)
                            cell_clean = re.sub(r'\D', '', cell_str)
                            if (phone_clean == cell_clean or 
                                cell_clean.endswith(phone_last7)):
                                results.append({
                                    'row': row_num + 1,
                                    'data': cell_str[:100]
                                })
                                if len(results) >= 5:
                                    return results
            
            elif file_path.endswith('.txt'):
                with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:
                    for line_num, line in enumerate(f):
                        if line_num > 50000:
                            break
                        line = line.strip()
                        if phone_number in line or phone_clean in re.sub(r'\D', '', line):
                            results.append({
                                'row': line_num + 1,
                                'data': line[:100]
                            })
                            if len(results) >= 5:
                                return results
        
        except Exception as e:
            pass
        
        return results
    
    def search_all(self, phone_number):
        if not self.loaded:
            self.scan_databases()
        
        if not self.databases_info:
            return None
        
        all_results = {}
        for name, info in self.databases_info.items():
            results = self.search_in_file(info['path'], phone_number)
            if results:
                all_results[name] = {
                    'info': info,
                    'matches': results,
                    'count': len(results)
                }
        
        return all_results if all_results else None


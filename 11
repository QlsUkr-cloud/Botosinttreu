@dp.message(InputStates.waiting_db_search)
async def search_in_databases(message: types.Message, state: FSMContext):
    phone = message.text.strip()
    phone_clean = re.sub(r'\D', '', phone)
    
    if len(phone_clean) < 7:
        await message.answer("❌ Введи корректный номер (минимум 7 цифр)")
        return
    
    await message.answer(f"🔍 **Ищу `{phone}` в базах данных...**\n\n⏳ Подожди...", parse_mode="Markdown")
    
    results = await asyncio.to_thread(db_searcher.search_all, phone)
    
    if not results:
        await message.answer(
            f"❌ **Ничего не найдено** для номера `{phone}`\n\n"
            f"📊 Проверено {len(db_searcher.databases_info)} баз(ы)",
            parse_mode="Markdown"
        )
    else:
        response = f"🔍 **Результаты поиска для `{phone}`**\n\n"
        response += f"✅ Найдено в {len(results)} базах:\n\n"
        
        for db_name, data in results.items():
            response += f"📁 **{db_name}** ({data['info']['size_mb']} МБ) - {data['count']} совпадений\n"
            for i, match in enumerate(data['matches'][:3]):
                response += f"  {i+1}. {match['data']}\n"
            response += "\n"
        
        response += "\n⚠️ *Данные из открытых источников. Проверяйте достоверность!*"
        
        if len(response) > 4000:
            for i in range(0, len(response), 4000):
                await message.answer(response[i:i+4000], parse_mode="Markdown")
        else:
            await message.answer(response, parse_mode="Markdown")
    
    await state.clear()
    await message.answer("Что дальше?", reply_markup=main_menu())

